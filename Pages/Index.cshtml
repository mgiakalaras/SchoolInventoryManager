@page
@model SchoolInventoryManager.Pages.IndexModel

@{
    ViewData["Title"] = "Κέντρο ελέγχου";

    var problemQuantity = Model.BrokenQuantity + Model.NeedsCheckQuantity + Model.ToWithdrawQuantity + Model.UnknownQuantity;
    var auditDate = Model.Settings.InventoryDate.ToString("dd/MM/yyyy");
    var needsAttention = problemQuantity > 0 || Model.LowStockSparePartRowsCount > 0 || Model.TechnicalIssueCount > 0;
    string Pct(double value) => value.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);
}

<section class="sim47-page">
    <section class="sim47-topline">
        <div class="sim47-identity">
            <span class="sim47-kicker">Operational command center</span>
            <h1>@Model.Settings.SchoolName</h1>
            <p>@Model.Settings.SchoolType · @Model.Settings.SchoolYear · Απογραφή @auditDate</p>
        </div>

        <div class="sim47-top-actions">
            <a class="sim47-btn primary" asp-page="/Items/Create">+ Νέο αντικείμενο</a>
            <a class="sim47-btn" asp-page="/InventoryAudits/FirstInventory">Πρώτη απογραφή</a>
            <a class="sim47-btn" asp-page="/Scanner/Index">Android Scanner</a>
        </div>
    </section>

    <section class="sim47-cockpit">
        <aside class="sim47-workspace">
            <div class="sim47-panel sim47-mode-panel">
                <span class="sim47-panel-label">Ροή εργασίας</span>
                <h2>Τι κάνουμε τώρα;</h2>

                <div class="sim47-mode-list">
                    <a asp-page="/InventoryAudits/Index" class="sim47-mode active">
                        <b>01</b>
                        <span>
                            <strong>Έλεγχος υπάρχουσας βάσης</strong>
                            <em>Σκανάρισμα QR σε υπάρχοντες χώρους.</em>
                        </span>
                    </a>

                    <a asp-page="/InventoryAudits/FirstInventory" class="sim47-mode">
                        <b>02</b>
                        <span>
                            <strong>Πρώτη απογραφή</strong>
                            <em>Χτίσιμο απογραφής από κινητό/tablet.</em>
                        </span>
                    </a>

                    <a asp-page="/InventoryAudits/MobileFindings" class="sim47-mode">
                        <b>03</b>
                        <span>
                            <strong>Review νέων ευρημάτων</strong>
                            <em>Έλεγχος όσων προστέθηκαν από Android.</em>
                        </span>
                    </a>

                    <a asp-page="/Labels/MobileFindings" class="sim47-mode">
                        <b>04</b>
                        <span>
                            <strong>QR νέων ευρημάτων</strong>
                            <em>Εκτύπωση ετικετών για νέα αντικείμενα.</em>
                        </span>
                    </a>
                </div>
            </div>

            <div class="sim47-panel sim47-helper-panel">
                <span class="sim47-panel-label">Βοηθός ροής</span>
                <h2>Νόβα check</h2>

                @if (Model.ItemsCount == 0)
                {
                    <p>Η βάση είναι άδεια. Ξεκίνα με import ή πρώτη απογραφή από Android.</p>
                    <a class="sim47-btn primary stretch" asp-page="/InventoryAudits/FirstInventory">Ξεκίνα πρώτη απογραφή</a>
                }
                else if (needsAttention)
                {
                    <p>Υπάρχουν σημεία που θέλουν προσοχή πριν θεωρηθεί η απογραφή καθαρή.</p>

                    <div class="sim47-helper-flags">
                        @if (problemQuantity > 0)
                        {
                            <a asp-page="/Reports/Index"><strong>@problemQuantity</strong><span>τεμάχια με θέμα</span></a>
                        }
                        @if (Model.LowStockSparePartRowsCount > 0)
                        {
                            <a asp-page="/SpareParts/Index"><strong>@Model.LowStockSparePartRowsCount</strong><span>χαμηλό απόθεμα</span></a>
                        }
                        @if (Model.TechnicalIssueCount > 0)
                        {
                            <a asp-page="/TechnicalReports/Index"><strong>@Model.TechnicalIssueCount</strong><span>τεχνικά θέματα</span></a>
                        }
                    </div>
                }
                else
                {
                    <p>Η εικόνα φαίνεται καθαρή. Επόμενο λογικό βήμα: QR ετικέτες ή φάκελος ετήσιου ελέγχου.</p>
                    <a class="sim47-btn stretch" asp-page="/Labels/Qr">Εκτύπωση QR</a>
                }
            </div>
        </aside>

        <main class="sim47-main-stage">
            <section class="sim47-metrics-ribbon">
                <article>
                    <span>Σύνολο</span>
                    <strong>@Model.TotalQuantity</strong>
                    <small>@Model.ItemsCount εγγραφές</small>
                </article>
                <article>
                    <span>Λειτουργικά</span>
                    <strong>@Model.WorkingQuantity</strong>
                    <small>@Pct(Model.WorkingPercent)%</small>
                </article>
                <article>
                    <span>Θέλουν προσοχή</span>
                    <strong>@problemQuantity</strong>
                    <small>@Pct(Model.ProblemPercent)%</small>
                </article>
                <article>
                    <span>Χώροι</span>
                    <strong>@Model.RoomsCount</strong>
                    <small>τοποθεσίες</small>
                </article>
                <article>
                    <span>Απόθεμα</span>
                    <strong>@Model.SparePartTotalQuantity</strong>
                    <small>@Model.LowStockSparePartRowsCount χαμηλό</small>
                </article>
            </section>

            <section class="sim47-stage-grid">
                <article class="sim47-panel sim47-map-panel">
                    <div class="sim47-panel-head">
                        <div>
                            <span class="sim47-panel-label">Χάρτης κατάστασης</span>
                            <h2>Κατανομή εξοπλισμού</h2>
                        </div>
                        <a class="sim47-btn small" asp-page="/Reports/Index">Αναφορές</a>
                    </div>

                    <div class="sim47-map-content">
                        <div class="sim47-donut" style="@Model.ConditionPieStyle">
                            <div>
                                <strong>@Model.ConditionPieTotalQuantity</strong>
                                <span>τεμάχια</span>
                            </div>
                        </div>

                        <div class="sim47-legend">
                            @if (!Model.ConditionSummaries.Any())
                            {
                                <div class="sim47-empty">Δεν υπάρχουν ακόμα δεδομένα κατάστασης.</div>
                            }
                            else
                            {
                                @foreach (var row in Model.ConditionSummaries)
                                {
                                    <div class="sim47-legend-row">
                                        <i class="@row.DotClass"></i>
                                        <span>@row.Name</span>
                                        <strong>@row.Quantity</strong>
                                        <em>@Pct(row.Percent)%</em>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </article>

                <article class="sim47-panel sim47-launchpad">
                    <div class="sim47-panel-head">
                        <div>
                            <span class="sim47-panel-label">Launchpad</span>
                            <h2>Άμεσες ενέργειες</h2>
                        </div>
                    </div>

                    <div class="sim47-launch-grid">
                        <a asp-page="/Items/Index"><b>▦</b><strong>Εξοπλισμός</strong><span>λίστα υλικού</span></a>
                        <a asp-page="/Rooms/Index"><b>⌂</b><strong>Χώροι</strong><span>αίθουσες/γραφεία</span></a>
                        <a asp-page="/Labels/Qr"><b>⌗</b><strong>QR ετικέτες</strong><span>εκτύπωση</span></a>
                        <a asp-page="/InventoryAudits/Index"><b>▣</b><strong>Απογραφές</strong><span>φάκελοι</span></a>
                        <a asp-page="/SpareParts/Index"><b>✚</b><strong>Απόθεμα</strong><span>ανταλλακτικά</span></a>
                        <a asp-page="/TechnicalReports/Index"><b>⚙</b><strong>Τεχνικός έλεγχος</strong><span>αναβαθμίσεις</span></a>
                    </div>
                </article>
            </section>

            <section class="sim47-wide-grid">
                <article class="sim47-panel">
                    <div class="sim47-panel-head">
                        <div>
                            <span class="sim47-panel-label">Κατηγορίες</span>
                            <h2>Τύποι εξοπλισμού</h2>
                        </div>
                    </div>

                    <div class="sim47-equipment-grid">
                        @if (!Model.CategorySummaries.Any())
                        {
                            <div class="sim47-empty">Δεν υπάρχουν ακόμα κατηγορίες με αντικείμενα.</div>
                        }
                        else
                        {
                            @foreach (var row in Model.CategorySummaries.Take(8))
                            {
                                <a class="sim47-equipment-tile" asp-page="/Items/Index" asp-route-Search="@row.Category">
                                    <b>@IconForCategory(row.Category)</b>
                                    <span>
                                        <strong>@row.Category</strong>
                                        <em>@row.Quantity τεμ. · @Pct(row.Percent)%</em>
                                    </span>
                                    <i><span style="width:@Pct(row.Percent)%"></span></i>
                                </a>
                            }
                        }
                    </div>
                </article>

                <article class="sim47-panel">
                    <div class="sim47-panel-head">
                        <div>
                            <span class="sim47-panel-label">Χώροι</span>
                            <h2>Πού υπάρχει υλικό</h2>
                        </div>
                    </div>

                    <div class="sim47-room-flow">
                        @if (!Model.RoomSummaries.Any())
                        {
                            <div class="sim47-empty">Δεν υπάρχουν ακόμα χώροι με αντικείμενα.</div>
                        }
                        else
                        {
                            @foreach (var row in Model.RoomSummaries.Take(9))
                            {
                                <a asp-page="/Items/Index" asp-route-Search="@row.Room">
                                    <strong>@row.Room</strong>
                                    <span>@row.Quantity τεμ.</span>
                                    <i><span style="width:@Pct(row.Percent)%"></span></i>
                                </a>
                            }
                        }
                    </div>
                </article>
            </section>
        </main>

        <aside class="sim47-side-feed">
            <div class="sim47-panel">
                <div class="sim47-panel-head">
                    <div>
                        <span class="sim47-panel-label">Τεχνικά</span>
                        <h2>Σήματα ελέγχου</h2>
                    </div>
                    <a class="sim47-btn small" asp-page="/TechnicalReports/Index">Άνοιγμα</a>
                </div>

                <div class="sim47-signal-stack">
                    <div><strong>@Model.MissingTechnicalSpecsCount</strong><span>χωρίς specs</span></div>
                    <div><strong>@Model.LowRamTechnicalCount</strong><span>χαμηλή RAM</span></div>
                    <div><strong>@Model.StorageUpgradeCandidateCount</strong><span>υποψήφιοι δίσκοι</span></div>
                </div>

                <div class="sim47-feed-list">
                    @if (!Model.TechnicalIssueItems.Any())
                    {
                        <div class="sim47-empty">Δεν υπάρχουν εμφανή τεχνικά θέματα.</div>
                    }
                    else
                    {
                        @foreach (var item in Model.TechnicalIssueItems.Take(4))
                        {
                            <a asp-page="/Items/Edit" asp-route-id="@item.Id">
                                <strong>@item.DisplayName</strong>
                                <span>@item.RoomName · @string.Join(", ", item.Issues)</span>
                            </a>
                        }
                    }
                </div>
            </div>

            <div class="sim47-panel">
                <div class="sim47-panel-head">
                    <div>
                        <span class="sim47-panel-label">Πρόσφατα</span>
                        <h2>Τελευταίες κινήσεις</h2>
                    </div>
                    <a class="sim47-btn small" asp-page="/Items/Index">Όλα</a>
                </div>

                <div class="sim47-feed-list">
                    @if (!Model.RecentItems.Any())
                    {
                        <div class="sim47-empty">Δεν υπάρχουν πρόσφατα αντικείμενα.</div>
                    }
                    else
                    {
                        @foreach (var item in Model.RecentItems.Take(6))
                        {
                            <a asp-page="/Items/Edit" asp-route-id="@item.Id">
                                <strong>@item.Name</strong>
                                <span>@item.Room?.Name · @item.Condition.GetDisplayName()</span>
                            </a>
                        }
                    }
                </div>
            </div>

            <div class="sim47-panel">
                <div class="sim47-panel-head">
                    <div>
                        <span class="sim47-panel-label">Απόθεμα</span>
                        <h2>Χαμηλά υλικά</h2>
                    </div>
                    <a class="sim47-btn small" asp-page="/SpareParts/Index">Άνοιγμα</a>
                </div>

                <div class="sim47-feed-list">
                    @if (!Model.LowStockParts.Any())
                    {
                        <div class="sim47-empty">Το απόθεμα δεν έχει χαμηλά υλικά.</div>
                    }
                    else
                    {
                        @foreach (var part in Model.LowStockParts.Take(5))
                        {
                            <a asp-page="/SpareParts/Edit" asp-route-id="@part.Id">
                                <strong>@part.Name</strong>
                                <span>@part.TypeLabel · απόθεμα @part.Quantity / ελάχιστο @part.MinimumStock</span>
                            </a>
                        }
                    }
                </div>
            </div>
        </aside>
    </section>
</section>

<style>
    .sim47-page {
        --gutter: clamp(.75rem, 1.15vw, 1.35rem);
        width: calc(100vw - (var(--gutter) * 2));
        margin-left: calc(50% - 50vw + var(--gutter));
        margin-right: calc(50% - 50vw + var(--gutter));
        display: grid;
        gap: var(--gutter);
        padding-bottom: 3rem;
    }

    .sim47-topline,
    .sim47-cockpit,
    .sim47-panel,
    .sim47-metrics-ribbon article {
        border: 1px solid rgba(148, 163, 184, .14);
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .08), transparent 34%),
            rgba(15, 23, 42, .82);
        box-shadow: 0 18px 44px rgba(0, 0, 0, .20);
    }

    .sim47-topline {
        border-radius: 26px;
        padding: clamp(1rem, 1.5vw, 1.55rem);
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: end;
    }

    .sim47-kicker,
    .sim47-panel-label {
        display: inline-flex;
        width: fit-content;
        margin-bottom: .55rem;
        padding: .26rem .58rem;
        border-radius: 999px;
        color: #a5f3fc;
        border: 1px solid rgba(34, 211, 238, .26);
        background: rgba(8, 47, 73, .36);
        font-weight: 900;
        font-size: .7rem;
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    .sim47-identity h1 {
        margin: 0;
        font-size: clamp(1.65rem, 2.5vw, 3.25rem);
        line-height: 1;
    }

    .sim47-identity p {
        margin: .45rem 0 0;
        color: #94a3b8;
    }

    .sim47-top-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .55rem;
        justify-content: flex-end;
    }

    .sim47-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: .55rem .8rem;
        border-radius: 13px;
        border: 1px solid rgba(148, 163, 184, .18);
        background: rgba(2, 6, 23, .34);
        color: #e5e7eb;
        font-weight: 850;
        text-decoration: none;
        white-space: nowrap;
    }

    .sim47-btn:hover {
        text-decoration: none;
        border-color: rgba(34, 211, 238, .32);
        background: rgba(8, 47, 73, .40);
    }

    .sim47-btn.primary {
        color: #06111f;
        border-color: transparent;
        background: linear-gradient(135deg, #22d3ee, #818cf8);
    }

    .sim47-btn.small {
        min-height: 32px;
        padding: .35rem .55rem;
        font-size: .82rem;
    }

    .sim47-btn.stretch {
        width: 100%;
    }

    .sim47-cockpit {
        display: grid;
        grid-template-columns: minmax(250px, .82fr) minmax(560px, 2.25fr) minmax(310px, .95fr);
        gap: var(--gutter);
        border-radius: 28px;
        padding: var(--gutter);
        background:
            linear-gradient(135deg, rgba(2, 6, 23, .55), rgba(15, 23, 42, .72)),
            radial-gradient(circle at 12% 18%, rgba(34, 211, 238, .12), transparent 28%),
            radial-gradient(circle at 82% 10%, rgba(129, 140, 248, .14), transparent 30%);
    }

    .sim47-workspace,
    .sim47-main-stage,
    .sim47-side-feed {
        display: grid;
        gap: var(--gutter);
        align-content: start;
    }

    .sim47-panel {
        border-radius: 22px;
        padding: 1rem;
    }

    .sim47-panel h2,
    .sim47-panel-head h2 {
        margin: 0;
        font-size: 1.08rem;
    }

    .sim47-panel p,
    .sim47-panel-head p {
        color: #94a3b8;
    }

    .sim47-panel-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: .8rem;
        margin-bottom: .85rem;
    }

    .sim47-mode-list,
    .sim47-feed-list,
    .sim47-legend,
    .sim47-room-flow {
        display: grid;
        gap: .55rem;
    }

    .sim47-mode,
    .sim47-feed-list a,
    .sim47-launch-grid a,
    .sim47-equipment-tile,
    .sim47-room-flow a,
    .sim47-helper-flags a {
        color: inherit;
        text-decoration: none;
        border: 1px solid rgba(148, 163, 184, .13);
        background: rgba(2, 6, 23, .33);
        transition: border-color .15s ease, background .15s ease, transform .15s ease;
    }

    .sim47-mode:hover,
    .sim47-feed-list a:hover,
    .sim47-launch-grid a:hover,
    .sim47-equipment-tile:hover,
    .sim47-room-flow a:hover,
    .sim47-helper-flags a:hover {
        transform: translateY(-1px);
        border-color: rgba(34, 211, 238, .30);
        background: rgba(15, 23, 42, .92);
        text-decoration: none;
    }

    .sim47-mode {
        display: grid;
        grid-template-columns: 38px minmax(0, 1fr);
        gap: .7rem;
        padding: .7rem;
        border-radius: 18px;
    }

    .sim47-mode.active {
        border-color: rgba(52, 211, 153, .30);
        background:
            radial-gradient(circle at top left, rgba(52, 211, 153, .12), transparent 38%),
            rgba(2, 6, 23, .35);
    }

    .sim47-mode b,
    .sim47-launch-grid b,
    .sim47-equipment-tile b {
        display: grid;
        place-items: center;
        min-width: 34px;
        height: 34px;
        border-radius: 13px;
        background: rgba(34, 211, 238, .12);
        border: 1px solid rgba(34, 211, 238, .20);
        color: #67e8f9;
    }

    .sim47-mode strong,
    .sim47-mode em,
    .sim47-feed-list strong,
    .sim47-feed-list span,
    .sim47-launch-grid strong,
    .sim47-launch-grid span,
    .sim47-equipment-tile strong,
    .sim47-equipment-tile em {
        display: block;
    }

    .sim47-mode strong,
    .sim47-feed-list strong,
    .sim47-launch-grid strong,
    .sim47-equipment-tile strong {
        color: #f8fafc;
        font-size: .9rem;
    }

    .sim47-mode em,
    .sim47-feed-list span,
    .sim47-launch-grid span,
    .sim47-equipment-tile em {
        color: #94a3b8;
        font-style: normal;
        font-size: .76rem;
        margin-top: .12rem;
    }

    .sim47-helper-flags {
        display: grid;
        grid-template-columns: 1fr;
        gap: .5rem;
    }

    .sim47-helper-flags a {
        border-radius: 16px;
        padding: .7rem;
        display: flex;
        justify-content: space-between;
        gap: .8rem;
        align-items: center;
    }

    .sim47-helper-flags strong {
        color: #fbbf24;
        font-size: 1.25rem;
    }

    .sim47-helper-flags span {
        color: #cbd5e1;
        font-size: .8rem;
    }

    .sim47-metrics-ribbon {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: var(--gutter);
    }

    .sim47-metrics-ribbon article {
        border-radius: 22px;
        padding: .9rem;
        min-height: 112px;
        display: grid;
        align-content: space-between;
    }

    .sim47-metrics-ribbon span,
    .sim47-metrics-ribbon small {
        color: #94a3b8;
        font-size: .75rem;
    }

    .sim47-metrics-ribbon strong {
        color: #f8fafc;
        font-size: clamp(1.55rem, 2.2vw, 2.45rem);
        line-height: 1;
    }

    .sim47-stage-grid,
    .sim47-wide-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(360px, .85fr);
        gap: var(--gutter);
    }

    .sim47-wide-grid {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }

    .sim47-map-content {
        display: grid;
        grid-template-columns: minmax(180px, 250px) minmax(0, 1fr);
        gap: 1rem;
        align-items: center;
    }

    .sim47-donut {
        width: min(230px, 100%);
        aspect-ratio: 1;
        border-radius: 999px;
        display: grid;
        place-items: center;
        margin: 0 auto;
    }

    .sim47-donut > div {
        width: 48%;
        aspect-ratio: 1;
        border-radius: 999px;
        display: grid;
        place-items: center;
        text-align: center;
        background: #111827;
        box-shadow: 0 0 0 1px rgba(148, 163, 184, .16);
    }

    .sim47-donut strong,
    .sim47-donut span {
        display: block;
    }

    .sim47-donut strong {
        align-self: end;
        color: #f8fafc;
        font-size: 1.35rem;
        line-height: 1;
    }

    .sim47-donut span {
        align-self: start;
        color: #94a3b8;
        font-size: .72rem;
        font-weight: 850;
        margin-top: .1rem;
    }

    .sim47-legend-row {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto auto;
        gap: .55rem;
        align-items: center;
        border-radius: 15px;
        padding: .55rem .65rem;
        background: rgba(2, 6, 23, .35);
        border: 1px solid rgba(148, 163, 184, .12);
    }

    .sim47-legend-row i {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: #38bdf8;
    }

    .sim47-legend-row span {
        color: #e5e7eb;
    }

    .sim47-legend-row strong {
        color: #f8fafc;
    }

    .sim47-legend-row em {
        color: #94a3b8;
        font-style: normal;
        font-size: .76rem;
    }

    .sim47-launch-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .65rem;
    }

    .sim47-launch-grid a {
        border-radius: 18px;
        padding: .75rem;
        min-height: 118px;
        display: grid;
        align-content: space-between;
