@page "{id:int}"
@model SchoolInventoryManager.Pages.Items.EditModel

@{
    ViewData["Title"] = "Επεξεργασία αντικειμένου";
}

<section class="page-header">
    <div>
        <h1>Επεξεργασία αντικειμένου</h1>
        <p>@Model.Item.Name</p>
    </div>
</section>

<form method="post" class="card">
    <input type="hidden" asp-for="Item.Id" />
    <input type="hidden" asp-for="Item.CreatedAt" />
    <input type="hidden" asp-for="ReturnUrl" />

    @{
        var itemViewData = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData);
        itemViewData.TemplateInfo.HtmlFieldPrefix = "Item";
    }

    <partial name="_ItemForm" model="Model.Item" view-data="itemViewData" />

    <div class="actions" style="margin-top:1rem;">
        <button class="btn" type="submit">Αποθήκευση</button>
        <a class="btn secondary" href="@Model.BackUrl">Άκυρο</a>
    </div>
</form>
