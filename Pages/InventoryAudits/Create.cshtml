@page
@model SchoolInventoryManager.Pages.InventoryAudits.CreateModel

@{
    ViewData["Title"] = "Νέος φάκελος απογραφής";
}

<section class="page-header">
    <div>
        <span class="hero-kicker">Νέα διαδικασία</span>
        <h1>Νέος φάκελος απογραφής</h1>
        <p>Ο φάκελος χρησιμοποιεί αυτόματα τα στοιχεία από τις Ρυθμίσεις σχολείου.</p>
    </div>

    <div class="actions">
        <a class="btn secondary" asp-page="./Index">Πίσω στους φακέλους</a>
        <a class="btn secondary" asp-page="/Settings/Index">Ρυθμίσεις σχολείου</a>
    </div>
</section>

@if (Model.MissingSchoolSettings)
{
    <div class="alert warning">
        Τα στοιχεία σχολείου φαίνονται ελλιπή ή προεπιλεγμένα. Καλό είναι να τα ενημερώσεις από τις Ρυθμίσεις πριν δημιουργήσεις επίσημο φάκελο απογραφής.
    </div>
}

<section class="grid grid-2">
    <form method="post" class="card">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <input asp-for="Folder.SchoolName" type="hidden" />
        <input asp-for="Folder.SchoolType" type="hidden" />
        <input asp-for="Folder.SchoolYear" type="hidden" />
        <input asp-for="Folder.ResponsibleName" type="hidden" />

        <div class="settings-snapshot-card">
            <h2>Στοιχεία φακέλου από τις Ρυθμίσεις</h2>

            <dl>
                <div>
                    <dt>Σχολική μονάδα</dt>
                    <dd>@Model.SettingsSchoolName</dd>
                </div>
                <div>
                    <dt>Τύπος σχολείου</dt>
                    <dd>@Model.SettingsSchoolType</dd>
                </div>
                <div>
                    <dt>Σχολικό έτος</dt>
                    <dd>@Model.SettingsSchoolYear</dd>
                </div>
                <div>
                    <dt>Υπεύθυνος/η</dt>
                    <dd>@(string.IsNullOrWhiteSpace(Model.SettingsResponsibleName) ? "-" : Model.SettingsResponsibleName)</dd>
                </div>
                <div>
                    <dt>Ημερομηνία απογραφής</dt>
                    <dd>@Model.SettingsInventoryDate</dd>
                </div>
            </dl>

            <p class="muted">
                Αυτά τα στοιχεία δεν αλλάζουν εδώ για να μη δημιουργούνται φάκελοι με λάθος σχολείο.
                Αν χρειάζεται διόρθωση, πήγαινε πρώτα στις Ρυθμίσεις σχολείου.
            </p>
        </div>

        <div class="form-row">
            <label asp-for="Folder.Title"></label>
            <input asp-for="Folder.Title" />
            <span asp-validation-for="Folder.Title"></span>
        </div>

        <div class="form-row">
            <label asp-for="Folder.AuditDate"></label>
            <input asp-for="Folder.AuditDate" type="date" />
            <span asp-validation-for="Folder.AuditDate"></span>
            <small class="muted">
                Προτείνεται από τις Ρυθμίσεις. Άλλαξέ το μόνο αν ο φάκελος αφορά άλλη ημερομηνία απογραφής.
            </small>
        </div>

        <div class="form-row">
            <label asp-for="Folder.Notes"></label>
            <textarea asp-for="Folder.Notes" rows="4"></textarea>
            <span asp-validation-for="Folder.Notes"></span>
        </div>

        <label class="check-row">
            <input asp-for="IncludeEmptyRooms" />
            <span>Να δημιουργηθούν εγγραφές και για άδειους χώρους</span>
        </label>

        <div class="actions">
            <button class="btn" type="submit">Δημιουργία φακέλου</button>
            <a class="btn secondary" asp-page="./Index">Άκυρο</a>
        </div>
    </form>

    <aside class="card">
        <h2>Τι θα δημιουργηθεί;</h2>
        <p class="muted">
            Με τη δημιουργία φακέλου θα δημιουργηθούν αυτόματα γραμμές ελέγχου για τους χώρους που έχουν ενεργό εξοπλισμό.
        </p>

        <div class="metric-grid">
            <div class="metric-card">
                <span>Χώροι με ενεργά υλικά</span>
                <strong>@Model.RoomsWithActiveItemsCount</strong>
            </div>
            <div class="metric-card">
                <span>Ενεργά αντικείμενα</span>
                <strong>@Model.ActiveItemsCount</strong>
            </div>
        </div>

        <div class="info-box">
            <strong>Ροή εργασίας</strong>
            <p>
                Δημιουργείς φάκελο, ανοίγεις κάθε χώρο, σκανάρεις QR, οριστικοποιείς τον χώρο και στο τέλος οριστικοποιείς τον φάκελο.
            </p>
        </div>

        <div class="info-box">
            <strong>Για χρήστες</strong>
            <p>
                Το επόμενο μεγάλο βήμα μπορεί να είναι login/ρόλοι ώστε να ξέρουμε ποιος δημιούργησε και ποιος οριστικοποίησε κάθε απογραφή.
            </p>
        </div>
    </aside>
</section>

<style>
    .settings-snapshot-card {
        border: 1px solid rgba(34, 211, 238, 0.22);
        border-radius: 20px;
        padding: 1rem;
        margin-bottom: 1rem;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, 0.10), transparent 34%),
            rgba(2, 6, 23, 0.28);
    }

    .settings-snapshot-card h2 {
        margin: 0 0 0.8rem;
        color: #f8fafc;
        font-size: 1.05rem;
    }

    .settings-snapshot-card dl {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.65rem;
        margin: 0 0 0.75rem;
    }

    .settings-snapshot-card div {
        border: 1px solid rgba(148, 163, 184, 0.14);
        border-radius: 14px;
        padding: 0.65rem;
        background: rgba(15, 23, 42, 0.42);
    }

    .settings-snapshot-card dt {
        color: #94a3b8;
        font-size: 0.75rem;
        font-weight: 850;
        margin-bottom: 0.2rem;
    }

    .settings-snapshot-card dd {
        color: #f8fafc;
        margin: 0;
        overflow-wrap: anywhere;
    }

    @@media (max-width: 720px) {
        .settings-snapshot-card dl {
            grid-template-columns: 1fr;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
