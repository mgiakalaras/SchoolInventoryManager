@page
@model SchoolInventoryManager.Pages.InventoryAudits.FirstInventoryModel

@{
    ViewData["Title"] = "Πρώτη απογραφή";
    var currentUrl = Url.Page("/InventoryAudits/FirstInventory", new { folderId = Model.FolderId });
}

<section class="first-inventory-page">
    <div class="first-inventory-hero">
        <div>
            <span class="first-inventory-badge">First inventory</span>
            <h1>Πρώτη απογραφή από μηδενική βάση</h1>
            <p>
                Συγκεντρωτική εικόνα για χώρους και αντικείμενα που δημιουργήθηκαν από κινητό/tablet
                κατά τη διαδικασία πρώτης απογραφής.
            </p>
        </div>

        <div class="first-inventory-actions">
            <a class="btn secondary" asp-page="./Index">Φάκελοι απογραφής</a>
            <a class="btn secondary" asp-page="./MobileFindings" asp-route-q="@Model.MarkerSearch">Νέα ευρήματα</a>
            <a class="btn" asp-page="/Labels/MobileFindings" asp-route-Search="@Model.MarkerSearch">QR νέων ευρημάτων</a>
        </div>
    </div>

    @if (Model.Folders.Count == 0)
    {
        <div class="first-inventory-card">
            <h2>Δεν υπάρχει φάκελος πρώτης απογραφής</h2>
            <p class="muted">
                Δημιούργησε νέο φάκελο απογραφής και διάλεξε
                <strong>Πρώτη απογραφή / από μηδενική βάση</strong>.
            </p>
            <a class="btn" asp-page="./Create">Νέος φάκελος απογραφής</a>
        </div>
    }
    else
    {
        <form method="get" class="first-inventory-card first-inventory-folder-picker">
            <label>
                <span>Φάκελος πρώτης απογραφής</span>
                <select name="folderId" onchange="this.form.submit()">
                    @foreach (var folder in Model.Folders)
                    {
                        <option value="@folder.Id" selected="@(folder.Id == Model.FolderId)">
                            @folder.Title (@folder.SchoolYear)
                        </option>
                    }
                </select>
            </label>

            <button class="btn secondary" type="submit">Άνοιγμα</button>

            @if (Model.SelectedFolder != null)
            {
                <a class="btn secondary" asp-page="./Details" asp-route-id="@Model.SelectedFolder.Id">Λεπτομέρειες φακέλου</a>
            }
        </form>

        @if (Model.SelectedFolder != null)
        {
            <div class="first-inventory-summary">
                <div class="first-inventory-stat">
                    <span>Χώροι</span>
                    <strong>@Model.TotalRooms</strong>
                </div>
                <div class="first-inventory-stat">
                    <span>Νέα αντικείμενα</span>
                    <strong>@Model.TotalItems</strong>
                </div>
                <div class="first-inventory-stat">
                    <span>Προς έλεγχο</span>
                    <strong>@Model.PendingReviewItems</strong>
                </div>
                <div class="first-inventory-stat">
                    <span>Χωρίς serial</span>
                    <strong>@Model.WithoutSerialItems</strong>
                </div>
                <div class="first-inventory-stat">
                    <span>Έτοιμα για QR</span>
                    <strong>@Model.ReadyForQrItems</strong>
                </div>
                <div class="first-inventory-stat">
                    <span>Κενοί χώροι</span>
                    <strong>@Model.EmptyRooms</strong>
                </div>
            </div>

            <div class="first-inventory-card">
                <h2>@Model.SelectedFolder.Title</h2>
                <p class="muted">
                    @Model.SelectedFolder.SchoolName · @Model.SelectedFolder.SchoolYear ·
                    @Model.SelectedFolder.AuditDate.ToString("dd/MM/yyyy")
                </p>

                <div class="first-inventory-workflow">
                    <div class="first-inventory-step">
                        <strong>1. Android</strong>
                        <span>Δημιουργία χώρων και νέων αντικειμένων ανά χώρο.</span>
                    </div>
                    <div class="first-inventory-step">
                        <strong>2. Web review</strong>
                        <span>Έλεγχος ονομασιών, serial, κατηγοριών και κατάστασης.</span>
                    </div>
                    <div class="first-inventory-step">
                        <strong>3. QR labels</strong>
                        <span>Εκτύπωση QR για τα νέα ευρήματα και δημιουργία baseline.</span>
                    </div>
                </div>
            </div>

            @if (Model.Rooms.Count == 0)
            {
                <div class="first-inventory-card">
                    <h2>Ο φάκελος είναι ακόμα κενός</h2>
                    <p class="muted">
                        Άνοιξε τον φάκελο από το Android Scanner και χρησιμοποίησε
                        <strong>+ Νέος χώρος</strong>.
                    </p>
                </div>
            }
            else
            {
                @foreach (var room in Model.Rooms)
                {
                    <section class="first-inventory-room">
                        <header>
                            <div>
                                <h2>@room.RoomName</h2>
                                <p>
                                    @room.Items.Count αντικείμενα από mobile ·
                                    @room.FoundItemsCount βρέθηκαν ·
                                    @room.UnknownItemsCount άγνωστα ·
                                    @(room.IsFinalized ? "Κλειδωμένος χώρος" : "Σε εξέλιξη")
                                </p>
                            </div>

                            <div class="first-inventory-room-actions">
                                @if (room.RoomId.HasValue)
                                {
                                    <a class="btn secondary" asp-page="./MobileFindings" asp-route-roomId="@room.RoomId" asp-route-q="@Model.MarkerSearch">
                                        Ευρήματα χώρου
                                    </a>
                                    <a class="btn secondary" asp-page="/Labels/MobileFindings" asp-route-RoomId="@room.RoomId" asp-route-Search="@Model.MarkerSearch">
                                        QR χώρου
                                    </a>
                                }
                            </div>
                        </header>

                        @if (room.Items.Count == 0)
                        {
                            <div class="first-inventory-empty-room">
                                Δεν έχουν προστεθεί νέα αντικείμενα σε αυτόν τον χώρο.
                            </div>
                        }
                        else
                        {
                            <div class="first-inventory-table-wrap">
                                <table class="first-inventory-table">
                                    <thead>
                                        <tr>
                                            <th>Κωδικός</th>
                                            <th>Αντικείμενο</th>
                                            <th>Κατηγορία</th>
                                            <th>Serial</th>
                                            <th>Ποσ.</th>
                                            <th>Ενέργειες</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in room.Items)
                                        {
                                            <tr>
                                                <td><code>@item.Code</code></td>
                                                <td>
                                                    <strong>@item.Name</strong>
                                                    @if (!string.IsNullOrWhiteSpace(item.BrandModel))
                                                    {
                                                        <span>@item.BrandModel</span>
                                                    }
                                                </td>
                                                <td>@item.CategoryName</td>
                                                <td>
                                                    @if (string.IsNullOrWhiteSpace(item.SerialNumber))
                                                    {
                                                        <span class="first-inventory-warning">Λείπει</span>
                                                    }
                                                    else
                                                    {
                                                        @item.SerialNumber
                                                    }
                                                </td>
                                                <td>@item.Quantity</td>
                                                <td>
                                                    <a class="btn small secondary"
                                                       asp-page="/Items/Edit"
                                                       asp-route-id="@item.Id"
                                                       asp-route-ReturnUrl="@currentUrl">
                                                        Επεξεργασία
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </section>
                }
            }
        }
    }
</section>

<style>
    .first-inventory-page {
        max-width: 1180px;
        margin: 0 auto;
        padding-bottom: 3rem;
    }

    .first-inventory-hero,
    .first-inventory-card,
    .first-inventory-room {
        border: 1px solid rgba(34, 211, 238, .22);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .10), transparent 38%),
            rgba(15, 23, 42, .86);
        box-shadow: 0 18px 42px rgba(0, 0, 0, .26);
        margin-bottom: 1rem;
    }

    .first-inventory-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: center;
        padding: 1.35rem;
    }

    .first-inventory-badge {
        display: inline-flex;
        width: fit-content;
        padding: .25rem .55rem;
        border-radius: 999px;
        border: 1px solid rgba(34, 211, 238, .32);
        color: #a5f3fc;
        background: rgba(8, 47, 73, .42);
        font-weight: 800;
        font-size: .72rem;
        letter-spacing: .03em;
        text-transform: uppercase;
        margin-bottom: .65rem;
    }

    .first-inventory-hero h1,
    .first-inventory-card h2,
    .first-inventory-room h2 {
        margin: 0;
    }

    .first-inventory-hero p,
    .first-inventory-card p,
    .first-inventory-room p {
        color: #94a3b8;
        margin-bottom: 0;
    }

    .first-inventory-actions,
    .first-inventory-room-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .55rem;
        justify-content: flex-end;
    }

    .first-inventory-card,
    .first-inventory-room {
        padding: 1rem;
    }

    .first-inventory-folder-picker {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) auto auto;
        gap: .75rem;
        align-items: end;
    }

    .first-inventory-folder-picker label span {
        display: block;
        font-weight: 800;
        margin-bottom: .35rem;
    }

    .first-inventory-folder-picker select {
        width: 100%;
        min-height: 42px;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, .22);
        background: rgba(2, 6, 23, .45);
        color: #e5eefb;
        padding: .65rem .75rem;
    }

    .first-inventory-summary {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: .75rem;
        margin-bottom: 1rem;
    }

    .first-inventory-stat {
        border: 1px solid rgba(148, 163, 184, .16);
        border-radius: 18px;
        background: rgba(2, 6, 23, .38);
        padding: .9rem;
    }

    .first-inventory-stat span {
        display: block;
        color: #94a3b8;
        font-size: .78rem;
        margin-bottom: .25rem;
    }

    .first-inventory-stat strong {
        display: block;
        font-size: 1.55rem;
        line-height: 1;
    }

    .first-inventory-workflow {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: .75rem;
        margin-top: 1rem;
    }

    .first-inventory-step {
        border: 1px solid rgba(148, 163, 184, .14);
        border-radius: 16px;
        background: rgba(2, 6, 23, .30);
        padding: .85rem;
    }

    .first-inventory-step strong,
    .first-inventory-step span {
        display: block;
    }

    .first-inventory-step span {
        color: #94a3b8;
        margin-top: .2rem;
    }

    .first-inventory-room header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: center;
        margin-bottom: .85rem;
    }

    .first-inventory-empty-room {
        border: 1px dashed rgba(148, 163, 184, .25);
        border-radius: 16px;
        padding: 1rem;
        color: #94a3b8;
    }

    .first-inventory-table-wrap {
        overflow-x: auto;
    }

    .first-inventory-table {
        width: 100%;
        border-collapse: collapse;
    }

    .first-inventory-table th,
    .first-inventory-table td {
        padding: .72rem;
        border-bottom: 1px solid rgba(148, 163, 184, .14);
        text-align: left;
        vertical-align: top;
    }

    .first-inventory-table th {
        color: #94a3b8;
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .03em;
    }

    .first-inventory-table td span {
        display: block;
        color: #94a3b8;
        margin-top: .18rem;
    }

    .first-inventory-warning {
        display: inline-flex !important;
        width: fit-content;
        padding: .18rem .45rem;
        border-radius: 999px;
        background: rgba(245, 158, 11, .16);
        color: #fbbf24 !important;
        font-weight: 800;
    }

    .btn.small {
        min-height: 0;
        padding: .35rem .55rem;
        font-size: .8rem;
    }

    @@media (max-width: 980px) {
        .first-inventory-hero,
        .first-inventory-room header,
        .first-inventory-folder-picker {
            grid-template-columns: 1fr;
        }

        .first-inventory-actions,
        .first-inventory-room-actions {
            justify-content: flex-start;
        }

        .first-inventory-summary,
        .first-inventory-workflow {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 640px) {
        .first-inventory-summary,
        .first-inventory-workflow {
            grid-template-columns: 1fr;
        }
    }
</style>
