@model SchoolInventoryManager.Models.InventoryItem
<div asp-validation-summary="ModelOnly"></div>
<div class="form-grid">
    <div class="form-row">
        <label asp-for="RoomId"></label>
        <select asp-for="RoomId" asp-items="ViewBag.Rooms">
            <option value="">-- επίλεξε χώρο --</option>
        </select>
        <span asp-validation-for="RoomId"></span>
    </div>
    <div class="form-row">
        <label asp-for="InventoryCategoryId"></label>
        <select asp-for="InventoryCategoryId" asp-items="ViewBag.Categories">
            <option value="">-- χωρίς κατηγορία --</option>
        </select>
        <span asp-validation-for="InventoryCategoryId"></span>
    </div>
    <div class="form-row">
        <label asp-for="Name"></label>
        <input asp-for="Name" placeholder="π.χ. Η/Υ, Οθόνη LG 19'', Βιντεοπροβολέας Epson" />
        <span asp-validation-for="Name"></span>
    </div>
    <div class="form-row">
        <label asp-for="Quantity"></label>
        <input asp-for="Quantity" type="number" min="1" />
        <span asp-validation-for="Quantity"></span>
    </div>
    <div class="form-row">
        <label asp-for="Brand"></label>
        <input asp-for="Brand" />
        <span asp-validation-for="Brand"></span>
    </div>
    <div class="form-row">
        <label asp-for="Model"></label>
        <input asp-for="Model" />
        <span asp-validation-for="Model"></span>
    </div>
    <div class="form-row">
        <label asp-for="SerialNumber"></label>
        <input asp-for="SerialNumber" />
        <span asp-validation-for="SerialNumber"></span>
    </div>
    <div class="form-row">
        <label asp-for="Condition"></label>
        <select asp-for="Condition" asp-items="Html.GetEnumSelectList<EquipmentCondition>()"></select>
        <span asp-validation-for="Condition"></span>
    </div>
    <div class="form-row full">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" placeholder="CPU/RAM/δίσκος/λειτουργικό ή γενική περιγραφή"></textarea>
        <span asp-validation-for="Description"></span>
    </div>
    <div class="form-row full">
        <label asp-for="Notes"></label>
        <textarea asp-for="Notes"></textarea>
        <span asp-validation-for="Notes"></span>
    </div>
</div>
