@page
@model SchoolInventoryManager.Pages.Scanner.IndexModel

@{
    ViewData["Title"] = "Android Scanner";
}

<style>
    .scanner-page {
        max-width: 1180px;
        margin: 0 auto;
        padding-bottom: 3rem;
    }

    .scanner-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1.25rem;
        align-items: center;
        padding: 1.35rem;
        border: 1px solid rgba(34, 211, 238, .22);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .16), transparent 38%),
            radial-gradient(circle at bottom right, rgba(52, 211, 153, .10), transparent 34%),
            linear-gradient(135deg, rgba(15, 23, 42, .98), rgba(17, 24, 39, .92));
        box-shadow: 0 18px 42px rgba(0, 0, 0, .28);
        margin-bottom: 1rem;
    }

    .scanner-hero h1,
    .scanner-card h2,
    .scanner-card h3 {
        margin: 0;
    }

    .scanner-hero p,
    .scanner-card p {
        margin-bottom: 0;
    }

    .scanner-badge {
        display: inline-flex;
        width: fit-content;
        padding: .25rem .55rem;
        border-radius: 999px;
        border: 1px solid rgba(34, 211, 238, .32);
        color: #a5f3fc;
        background: rgba(8, 47, 73, .42);
        font-weight: 800;
        font-size: .72rem;
        letter-spacing: .03em;
        text-transform: uppercase;
        margin-bottom: .65rem;
    }

    .scanner-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .55rem;
        justify-content: flex-end;
    }

    .scanner-grid {
        display: grid;
        grid-template-columns: minmax(300px, 420px) minmax(0, 1fr);
        gap: 1rem;
        align-items: start;
    }

    .scanner-card {
        border: 1px solid rgba(148, 163, 184, .16);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .06), transparent 40%),
            rgba(15, 23, 42, .82);
        padding: 1rem;
        box-shadow: 0 14px 34px rgba(0, 0, 0, .22);
        margin-bottom: 1rem;
    }

    .scanner-card.success {
        border-color: rgba(52, 211, 153, .26);
        background:
            radial-gradient(circle at top left, rgba(52, 211, 153, .10), transparent 36%),
            rgba(6, 30, 25, .72);
    }

    .scanner-card.warning {
        border-color: rgba(245, 158, 11, .30);
        background:
            radial-gradient(circle at top left, rgba(245, 158, 11, .12), transparent 36%),
            rgba(30, 23, 10, .72);
    }

    .scanner-steps {
        counter-reset: scanner-step;
        display: grid;
        gap: .65rem;
    }

    .scanner-step {
        counter-increment: scanner-step;
        display: grid;
        grid-template-columns: 42px minmax(0, 1fr);
        gap: .75rem;
        align-items: start;
        padding: .85rem;
        border: 1px solid rgba(148, 163, 184, .14);
        border-radius: 16px;
        background: rgba(2, 6, 23, .30);
    }

    .scanner-step::before {
        content: counter(scanner-step);
        display: grid;
        place-items: center;
        width: 34px;
        height: 34px;
        border-radius: 12px;
        background: rgba(34, 211, 238, .14);
        color: #67e8f9;
        font-weight: 900;
        border: 1px solid rgba(34, 211, 238, .32);
    }

    .scanner-step strong,
    .scanner-step span {
        display: block;
    }

    .scanner-step span {
        color: #94a3b8;
        margin-top: .2rem;
    }

    .scanner-code {
        display: block;
        width: 100%;
        padding: .8rem;
        border-radius: 14px;
        border: 1px solid rgba(148, 163, 184, .16);
        background: rgba(2, 6, 23, .46);
        color: #a5f3fc;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        overflow-x: auto;
        white-space: nowrap;
    }

    .scanner-checklist {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: .55rem;
    }

    .scanner-checklist li {
        padding: .7rem .8rem;
        border-radius: 14px;
        border: 1px solid rgba(148, 163, 184, .14);
        background: rgba(2, 6, 23, .28);
        color: #cbd5e1;
    }

    .scanner-checklist li::before {
        content: "✓";
        color: #34d399;
        font-weight: 900;
        margin-right: .55rem;
    }

    .scanner-warning-list li::before {
        content: "!";
        color: #f59e0b;
    }

    @@media (max-width: 900px) {
        .scanner-hero,
        .scanner-grid {
            grid-template-columns: 1fr;
        }

        .scanner-actions {
            justify-content: flex-start;
        }
    }
</style>

<div class="scanner-page">
    <section class="scanner-hero">
        <div>
            <span class="scanner-badge">Mobile QR workflow</span>
            <h1>Android Scanner</h1>
            <p class="muted">
                Η κάμερα QR γίνεται από κινητό ή tablet. Το web app μένει το κέντρο διαχείρισης, αναφορών και οριστικοποίησης.
            </p>
        </div>

        <div class="scanner-actions">
            <a class="btn primary" asp-page="/InventoryAudits/Index">Φάκελοι απογραφής</a>
            <a class="btn secondary" asp-page="/Audit/Room">Χειροκίνητος έλεγχος</a>
            <a class="btn secondary" asp-page="/Labels/Qr">QR ετικέτες</a>
        </div>
    </section>

    <div class="scanner-grid">
        <div>
            <section class="scanner-card success">
                <h2>Τι κάνει</h2>
                <p class="muted">
                    Η εφαρμογή Android συνδέεται στον server, φορτώνει φακέλους/χώρους και στέλνει κάθε scan πίσω στη βάση.
                </p>

                <ul class="scanner-checklist" style="margin-top: .9rem;">
                    <li>Σάρωση QR με κάμερα</li>
                    <li>Χειροκίνητη καταχώρηση κωδικού ως fallback</li>
                    <li>Live ενημέρωση βρέθηκαν / λείπουν</li>
                    <li>Συγχρονισμός με web app και φάκελο απογραφής</li>
                </ul>
            </section>

            <section class="scanner-card warning">
                <h2>Πριν το χρησιμοποιήσεις</h2>

                <ul class="scanner-checklist scanner-warning-list" style="margin-top: .9rem;">
                    <li>Το κινητό πρέπει να βλέπει τον server από browser.</li>
                    <li>Ο φάκελος απογραφής πρέπει να έχει δημιουργηθεί μετά την εισαγωγή των αντικειμένων.</li>
                    <li>Τα QR labels πρέπει να έχουν σωστό Application Base URL.</li>
                    <li>Για κάμερα σε Android δεν χρησιμοποιούμε browser scanner από το web.</li>
                </ul>
            </section>

            <section class="scanner-card">
                <h2>Server URL</h2>
                <p class="muted">
                    Βάλε στην Android εφαρμογή τη διεύθυνση που ανοίγει από το κινητό.
                </p>

                <code class="scanner-code">@Model.SuggestedServerUrl</code>

                <p class="muted" style="margin-top: .75rem;">
                    Health check:
                </p>

                <code class="scanner-code">@Model.SuggestedServerUrl/api/mobile/health</code>
            </section>
        </div>

        <div>
            <section class="scanner-card">
                <h2>Ροή χρήσης</h2>

                <div class="scanner-steps" style="margin-top: .9rem;">
                    <div class="scanner-step">
                        <div>
                            <strong>Δημιούργησε φάκελο απογραφής στο web app</strong>
                            <span>Ο φάκελος φτιάχνει χώρους και αναμενόμενα αντικείμενα.</span>
                        </div>
                    </div>

                    <div class="scanner-step">
                        <div>
                            <strong>Άνοιξε την Android εφαρμογή</strong>
                            <span>Βάλε το server URL και κάνε έλεγχο σύνδεσης.</span>
                        </div>
                    </div>

                    <div class="scanner-step">
                        <div>
                            <strong>Επίλεξε φάκελο και χώρο</strong>
                            <span>Το app φορτώνει την επίσημη απογραφή του χώρου.</span>
                        </div>
                    </div>

                    <div class="scanner-step">
                        <div>
                            <strong>Σκάναρε τα QR</strong>
                            <span>Κάθε scan ενημερώνει τον server και τη λίστα βρέθηκαν / λείπουν.</span>
                        </div>
                    </div>

                    <div class="scanner-step">
                        <div>
                            <strong>Έλεγξε και οριστικοποίησε από το web app</strong>
                            <span>Η τελική επιβεβαίωση γίνεται από τον φάκελο απογραφής.</span>
                        </div>
                    </div>
                </div>
            </section>

            <section class="scanner-card">
                <h2>Δοκιμή από κινητό</h2>
                <p class="muted">
                    Άνοιξε από browser στο κινητό:
                </p>

                <code class="scanner-code">@Model.SuggestedServerUrl/api/mobile/health</code>

                <p class="muted" style="margin-top:.75rem;">
                    Αν δεν ανοίγει αυτό, δεν θα δουλέψει ούτε η Android εφαρμογή.
                </p>
            </section>

            <section class="scanner-card">
                <h2>APK / εγκατάσταση</h2>
                <p class="muted">
                    Προς το παρόν το Android Scanner εγκαθίσταται χειροκίνητα ως sideload APK για δοκιμές.
                    Κανονικό signed release θα γίνει αργότερα όταν σταθεροποιηθεί η εφαρμογή.
                </p>

                <div class="scanner-actions" style="justify-content:flex-start; margin-top:.9rem;">
                    <a class="btn secondary" href="https://github.com/mgiakalaras/SchoolInventoryManager" target="_blank" rel="noopener">GitHub repository</a>
                </div>
            </section>
        </div>
    </div>
</div>
