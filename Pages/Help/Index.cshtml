@page
@model SchoolInventoryManager.Pages.Help.IndexModel

@{
    ViewData["Title"] = "Οδηγίες χρήσης";
}

<style>
    .help-page {
        max-width: 1180px;
        margin: 0 auto;
        padding-bottom: 3rem;
    }

    .help-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1.25rem;
        align-items: center;
        padding: 1.35rem;
        border: 1px solid rgba(34, 211, 238, .22);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .16), transparent 38%),
            radial-gradient(circle at bottom right, rgba(52, 211, 153, .10), transparent 34%),
            linear-gradient(135deg, rgba(15, 23, 42, .98), rgba(17, 24, 39, .92));
        box-shadow: 0 18px 42px rgba(0, 0, 0, .28);
        margin-bottom: 1rem;
    }

    .help-hero h1,
    .help-card h2,
    .help-card h3 {
        margin: 0;
    }

    .help-badge {
        display: inline-flex;
        width: fit-content;
        padding: .25rem .55rem;
        border-radius: 999px;
        border: 1px solid rgba(34, 211, 238, .32);
        color: #a5f3fc;
        background: rgba(8, 47, 73, .42);
        font-weight: 800;
        font-size: .72rem;
        letter-spacing: .03em;
        text-transform: uppercase;
        margin-bottom: .65rem;
    }

    .help-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .55rem;
        justify-content: flex-end;
    }

    .help-grid {
        display: grid;
        grid-template-columns: minmax(300px, 390px) minmax(0, 1fr);
        gap: 1rem;
        align-items: start;
    }

    .help-card {
        border: 1px solid rgba(148, 163, 184, .16);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .06), transparent 40%),
            rgba(15, 23, 42, .82);
        padding: 1rem;
        box-shadow: 0 14px 34px rgba(0, 0, 0, .22);
        margin-bottom: 1rem;
    }

    .help-card.success {
        border-color: rgba(52, 211, 153, .26);
        background:
            radial-gradient(circle at top left, rgba(52, 211, 153, .10), transparent 36%),
            rgba(6, 30, 25, .72);
    }

    .help-card.warning {
        border-color: rgba(245, 158, 11, .30);
        background:
            radial-gradient(circle at top left, rgba(245, 158, 11, .12), transparent 36%),
            rgba(30, 23, 10, .72);
    }

    .help-nav-list,
    .help-checklist {
        list-style: none;
        padding: 0;
        margin: .9rem 0 0;
        display: grid;
        gap: .55rem;
    }

    .help-nav-list a {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: .7rem;
        align-items: center;
        padding: .78rem .85rem;
        border-radius: 15px;
        border: 1px solid rgba(148, 163, 184, .14);
        background: rgba(2, 6, 23, .30);
        text-decoration: none;
        color: #e5eefb;
    }

    .help-nav-list a::after {
        content: "→";
        color: #22d3ee;
        font-weight: 900;
    }

    .help-checklist li {
        padding: .75rem .85rem;
        border-radius: 15px;
        border: 1px solid rgba(148, 163, 184, .14);
        background: rgba(2, 6, 23, .30);
        color: #cbd5e1;
    }

    .help-checklist li::before {
        content: "✓";
        color: #34d399;
        font-weight: 900;
        margin-right: .55rem;
    }

    .help-warning-list li::before {
        content: "!";
        color: #f59e0b;
    }

    .help-steps {
        counter-reset: help-step;
        display: grid;
        gap: .65rem;
        margin-top: .9rem;
    }

    .help-step {
        counter-increment: help-step;
        display: grid;
        grid-template-columns: 42px minmax(0, 1fr);
        gap: .75rem;
        align-items: start;
        padding: .85rem;
        border: 1px solid rgba(148, 163, 184, .14);
        border-radius: 16px;
        background: rgba(2, 6, 23, .30);
    }

    .help-step::before {
        content: counter(help-step);
        display: grid;
        place-items: center;
        width: 34px;
        height: 34px;
        border-radius: 12px;
        background: rgba(34, 211, 238, .14);
        color: #67e8f9;
        font-weight: 900;
        border: 1px solid rgba(34, 211, 238, .32);
    }

    .help-step strong,
    .help-step span {
        display: block;
    }

    .help-step span {
        color: #94a3b8;
        margin-top: .2rem;
    }

    .help-section-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    @@media (max-width: 900px) {
        .help-hero,
        .help-grid,
        .help-section-grid {
            grid-template-columns: 1fr;
        }

        .help-actions {
            justify-content: flex-start;
        }
    }
</style>

<div class="help-page">
    <section class="help-hero">
        <div>
            <span class="help-badge">Οδηγίες χρήσης</span>
            <h1>School Inventory Manager</h1>
            <p class="muted">
                Γρήγορη εικόνα για τη σωστή ροή: πρώτα στήνεις χώρους/εξοπλισμό, μετά δημιουργείς φάκελο απογραφής,
                σκανάρεις από Android και οριστικοποιείς από το web app.
            </p>
        </div>

        <div class="help-actions">
            <a class="btn primary" asp-page="/InventoryAudits/Index">Φάκελοι απογραφής</a>
            <a class="btn secondary" asp-page="/Scanner/Index">Android Scanner</a>
            <a class="btn secondary" asp-page="/Labels/Qr">QR ετικέτες</a>
        </div>
    </section>

    <div class="help-grid">
        <aside>
            <section class="help-card">
                <h2>Γρήγορη πλοήγηση</h2>
                <ul class="help-nav-list">
                    <li><a asp-page="/Settings/Index">Ρυθμίσεις σχολείου</a></li>
                    <li><a asp-page="/Rooms/Index">Χώροι</a></li>
                    <li><a asp-page="/Items/Index">Εξοπλισμός</a></li>
                    <li><a asp-page="/ImportExport/Index">Import / Export</a></li>
                    <li><a asp-page="/Labels/Qr">QR ετικέτες</a></li>
                    <li><a asp-page="/InventoryAudits/Index">Φάκελοι απογραφής</a></li>
                    <li><a asp-page="/Audit/Room">Χειροκίνητος έλεγχος χώρου</a></li>
                    <li><a asp-page="/Scanner/Index">Android Scanner</a></li>
                    <li><a asp-page="/Destructions/Index">Καταστροφή υλικού</a></li>
                    <li><a asp-page="/SpareParts/Index">Ανταλλακτικά / Απόθεμα</a></li>
                </ul>
            </section>

            <section class="help-card warning">
                <h2>Σημαντικό</h2>
                <ul class="help-checklist help-warning-list">
                    <li>Η κάμερα QR γίνεται από Android κινητό ή tablet, όχι από browser υπολογιστή.</li>
                    <li>Το web app είναι για διαχείριση, χειροκίνητο έλεγχο, αναφορές και οριστικοποίηση.</li>
                    <li>Πριν εκτυπώσεις QR labels, έλεγξε το Application Base URL στις ρυθμίσεις.</li>
                    <li>Πριν από σοβαρό update κράτα backup της βάσης ή του Docker volume.</li>
                </ul>
            </section>
        </aside>

        <main>
            <section class="help-card success">
                <h2>Βασική ροή απογραφής με QR</h2>

                <div class="help-steps">
                    <div class="help-step">
                        <div>
                            <strong>Συμπλήρωσε τις ρυθμίσεις σχολείου</strong>
                            <span>Όνομα σχολείου, τύπος, σχολικό έτος, υπεύθυνος και Application Base URL.</span>
                        </div>
                    </div>

                    <div class="help-step">
                        <div>
                            <strong>Πέρασε χώρους και εξοπλισμό</strong>
                            <span>Με χειροκίνητη καταχώρηση ή import από Excel.</span>
                        </div>
                    </div>

                    <div class="help-step">
                        <div>
                            <strong>Εκτύπωσε QR ετικέτες</strong>
                            <span>Από τη σελίδα QR ετικετών, ανά χώρο/κατηγορία ή με επιλογή συγκεκριμένων αντικειμένων.</span>
                        </div>
                    </div>

                    <div class="help-step">
                        <div>
                            <strong>Δημιούργησε φάκελο απογραφής</strong>
                            <span>Ο φάκελος δημιουργεί room sessions και κρατά την επίσημη πρόοδο.</span>
                        </div>
                    </div>

                    <div class="help-step">
                        <div>
                            <strong>Σκάναρε από Android</strong>
                            <span>Επίλεξε φάκελο, χώρο και σκάναρε QR με κινητό ή tablet.</span>
                        </div>
                    </div>

                    <div class="help-step">
                        <div>
                            <strong>Έλεγξε / οριστικοποίησε από web</strong>
                            <span>Δες βρέθηκαν/λείπουν/θέματα, κάνε διορθώσεις και οριστικοποίησε.</span>
                        </div>
                    </div>
                </div>
            </section>

            <section class="help-section-grid">
                <article class="help-card">
                    <h2>Χειροκίνητος έλεγχος χώρου</h2>
                    <p class="muted">
                        Χρησιμοποιείται από υπολογιστή για έλεγχο, διόρθωση ή χειροκίνητη καταχώρηση κωδικού.
                        Αν υπάρχει ενεργός φάκελος, η σελίδα συνδέεται με το σωστό room session.
                    </p>

                    <div class="help-actions" style="justify-content:flex-start; margin-top:.9rem;">
                        <a class="btn secondary" asp-page="/Audit/Room">Άνοιγμα χειροκίνητου ελέγχου</a>
                    </div>
                </article>

                <article class="help-card">
                    <h2>Android Scanner</h2>
                    <p class="muted">
                        Η εφαρμογή Android είναι η επίσημη λύση για camera QR scanning. Το κινητό πρέπει να βλέπει τον server.
                    </p>

                    <div class="help-actions" style="justify-content:flex-start; margin-top:.9rem;">
                        <a class="btn secondary" asp-page="/Scanner/Index">Οδηγίες Android Scanner</a>
                    </div>
                </article>
            </section>

            <section class="help-card">
                <h2>Καθαρισμός / διαγραφή λάθος φακέλου</h2>
                <p class="muted">
                    Αν δημιουργήσεις λάθος φάκελο απογραφής, μπορείς όσο είναι πρόχειρος να καθαρίσεις τα scans ή να τον διαγράψεις.
                    Τα αντικείμενα απογραφής δεν διαγράφονται.
                </p>

                <ul class="help-checklist">
                    <li>Καθαρισμός scans: μηδενίζει την πρόοδο του φακέλου.</li>
                    <li>Διαγραφή πρόχειρου φακέλου: αφαιρεί τον φάκελο, τα room sessions και τα scan logs.</li>
                    <li>Οριστικοποιημένος φάκελος δεν διαγράφεται από την κανονική ροή.</li>
                </ul>
            </section>
        </main>
    </div>
</div>
