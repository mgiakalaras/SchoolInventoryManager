@page
@model SchoolInventoryManager.Pages.Items.CreateModel
@{
    ViewData["Title"] = "Νέο αντικείμενο";
}

<section class="page-header">
    <div>
        <h1>Νέο αντικείμενο</h1>
        <p>Πρόσθεσε εξοπλισμό σε συγκεκριμένο χώρο.</p>
    </div>
</section>

<form method="post" class="card">
    @{
        var itemViewData = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData);
        itemViewData.TemplateInfo.HtmlFieldPrefix = "Item";
    }
    <partial name="_ItemForm" model="Model.Item" view-data="itemViewData" />
    <div class="actions" style="margin-top:1rem;">
        <button class="btn" type="submit">Αποθήκευση</button>
        <a class="btn secondary" asp-page="Index">Άκυρο</a>
    </div>
</form>
