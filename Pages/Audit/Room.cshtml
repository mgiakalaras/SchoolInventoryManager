@page
@model SchoolInventoryManager.Pages.Audit.RoomModel

@{
    ViewData["Title"] = Model.IsFolderMode
        ? $"Χειροκίνητος έλεγχος χώρου - {Model.SelectedRoomName}"
        : "Χειροκίνητος έλεγχος χώρου";
}

<section class="hero compact-hero">
    <div>
        <span class="eyebrow">Απογραφή χώρου</span>
        <h1>Χειροκίνητος έλεγχος χώρου</h1>
        <p class="muted">
            Η σάρωση QR με κάμερα γίνεται από την Android εφαρμογή.
            Από το web app μπορείς να κάνεις χειροκίνητη καταχώρηση κωδικού, έλεγχο και διαχείριση χώρου.
        </p>
    </div>

    <div class="hero-actions">
        @if (Model.FolderId.HasValue)
        {
            <a class="btn secondary" asp-page="/InventoryAudits/Details" asp-route-id="@Model.FolderId.Value">Πίσω στον φάκελο</a>
        }

        <a class="btn secondary" asp-page="/InventoryAudits/Index">Φάκελοι απογραφής</a>
        <a class="btn secondary" asp-page="/Labels/Qr">QR ετικέτες</a>
    </div>
</section>

@if (TempData["Message"] is string message)
{
    <div class="alert success">@message</div>
}

@if (TempData["Warning"] is string warning)
{
    <div class="alert warning">@warning</div>
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>Επιλογή χώρου</h2>
            <p class="muted">
                Για επίσημη απογραφή προτίμησε να ανοίγεις τον χώρο μέσα από φάκελο απογραφής.
                Εκεί αποθηκεύονται οι καταχωρήσεις και η πρόοδος.
            </p>
        </div>
    </div>

    <form method="get" class="form-grid">
        @if (Model.FolderId.HasValue)
        {
            <input type="hidden" name="FolderId" value="@Model.FolderId.Value" />
        }

        @if (Model.RoomSessionId.HasValue)
        {
            <input type="hidden" name="RoomSessionId" value="@Model.RoomSessionId.Value" />
        }

        <label>
            <span>Χώρος</span>
            <select asp-for="RoomId" asp-items="Model.Rooms">
                <option value="">-- επίλεξε χώρο --</option>
            </select>
        </label>

        <div class="form-actions">
            <button type="submit" class="btn primary">Φόρτωση χώρου</button>
        </div>
    </form>
</section>

@if (!Model.RoomId.HasValue)
{
    <section class="empty-state">
        <h2>Επίλεξε χώρο για να ξεκινήσεις</h2>
        <p>
            Από εδώ γίνεται μόνο χειροκίνητη καταχώρηση / έλεγχος.
            Για κάμερα QR χρησιμοποίησε την Android εφαρμογή.
        </p>
    </section>
}
else
{
    <section class="panel">
        <div class="panel-header">
            <div>
                <span class="eyebrow">Χώρος</span>
                <h2>@Model.SelectedRoomName</h2>

                @if (Model.IsFolderMode)
                {
                    <p class="muted">
                        Φάκελος: <strong>@Model.Folder!.Title</strong> ·
                        Κατάσταση χώρου:
                        <strong>@(Model.RoomSession!.IsFinalized ? "Οριστικοποιημένος" : (Model.RoomSession.CompletedAt.HasValue ? "Ολοκληρωμένος" : "Πρόχειρος"))</strong> ·
                        Καταχωρήσεις: <strong>@Model.SavedScans.Count</strong>
                    </p>
                }
                else
                {
                    <p class="muted">
                        Live έλεγχος χωρίς φάκελο. Η αναζήτηση δείχνει στοιχεία αντικειμένου, αλλά δεν αποθηκεύει επίσημη πρόοδο.
                    </p>
                }
            </div>

            @if (Model.IsFolderMode)
            {
                <div class="hero-actions">
                    @if (!Model.RoomSession!.IsFinalized && !Model.Folder!.IsFinalized)
                    {
                        <form method="post" asp-page-handler="FinalizeRoom" asp-route-roomSessionId="@Model.RoomSession.Id">
                            <button type="submit" class="btn primary">Οριστικοποίηση χώρου</button>
                        </form>

                        <form method="post" asp-page-handler="ClearRoomScans" asp-route-roomSessionId="@Model.RoomSession.Id"
                              onsubmit="return confirm('Να καθαριστούν όλες οι χειροκίνητες/QR καταχωρήσεις αυτού του χώρου;');">
                            <button type="submit" class="btn danger">Καθαρισμός καταχωρήσεων</button>
                        </form>
                    }
                    else if (Model.RoomSession!.IsFinalized && !Model.Folder!.IsFinalized)
                    {
                        <form method="post" asp-page-handler="ReopenRoom" asp-route-roomSessionId="@Model.RoomSession.Id">
                            <button type="submit" class="btn secondary">Άνοιγμα για διορθώσεις</button>
                        </form>
                    }
                </div>
            }
        </div>

        @if (Model.IsLocked)
        {
            <div class="alert warning">
                Ο χώρος ή ο φάκελος είναι οριστικοποιημένος. Δεν επιτρέπονται νέες καταχωρήσεις.
            </div>
        }

        <div class="stats-grid">
            <article class="stat-card">
                <span>Αναμενόμενα</span>
                <strong>@Model.ExpectedItems.Count</strong>
            </article>

            <article class="stat-card success">
                <span>Βρέθηκαν</span>
                <strong>@(Model.RoomSession?.FoundItemsCount ?? Model.SavedScans.Count(x => x.Status == SchoolInventoryManager.Models.AuditScanStatus.Found))</strong>
            </article>

            <article class="stat-card warning">
                <span>Λείπουν</span>
                <strong>@Model.MissingItems.Count</strong>
            </article>

            <article class="stat-card danger">
                <span>Θέματα</span>
                <strong>@(Model.WrongRoomScans.Count + Model.UnknownScans.Count)</strong>
            </article>
        </div>
    </section>

    <section class="panel">
        <div class="panel-header">
            <div>
                <h2>Χειροκίνητη καταχώρηση</h2>
                <p class="muted">
                    Γράψε τον κωδικό απογραφής ή ολόκληρο QR URL. Η καταχώρηση αποθηκεύεται μόνο όταν ο χώρος έχει ανοιχτεί μέσα από φάκελο απογραφής.
                </p>
            </div>
        </div>

        <form method="post" asp-page-handler="ManualScan" class="manual-scan-form">
            @if (Model.FolderId.HasValue)
            {
                <input type="hidden" name="FolderId" value="@Model.FolderId.Value" />
            }

            @if (Model.RoomSessionId.HasValue)
            {
                <input type="hidden" name="RoomSessionId" value="@Model.RoomSessionId.Value" />
            }

            <input type="hidden" name="RoomId" value="@Model.RoomId.Value" />

            <label>
                <span>Κωδικός / QR URL</span>
                <input name="code" value="" placeholder="SIM-2026-000123 ή http://server/q/SIM-2026-000123" autocomplete="off" />
            </label>

            <button type="submit" class="btn primary" @(Model.IsLocked ? "disabled" : "")>Καταχώρηση</button>
        </form>

        @if (Model.LastLookup is not null)
        {
            <div class="lookup-result @(Model.LastLookup.Found ? "success" : "warning")">
                <h3>@(Model.LastLookup.Found ? Model.LastLookup.Name : "Δεν βρέθηκε αντικείμενο")</h3>
                <p>@Model.LastLookup.Message</p>

                @if (Model.LastLookup.Found)
                {
                    <dl class="details-list">
                        <dt>Κωδικός</dt>
                        <dd>@Model.LastLookup.Code</dd>

                        <dt>Χώρος αντικειμένου</dt>
                        <dd>@Model.LastLookup.RoomName</dd>

                        <dt>Κατηγορία</dt>
                        <dd>@Model.LastLookup.CategoryName</dd>

                        <dt>Serial</dt>
                        <dd>@(string.IsNullOrWhiteSpace(Model.LastLookup.SerialNumber) ? "-" : Model.LastLookup.SerialNumber)</dd>
                    </dl>

                    <div class="hero-actions">
                        <a class="btn secondary" href="@Model.LastLookup.ItemCardUrl">Προβολή καρτέλας</a>
                        <a class="btn secondary" href="@Model.LastLookup.EditUrl">Επεξεργασία</a>
                    </div>
                }
            </div>
        }
    </section>

    <section class="grid two-columns">
        <article class="panel">
            <div class="panel-header">
                <div>
                    <h2>Αναμενόμενα αντικείμενα</h2>
                    <p class="muted">Τα αντικείμενα που είναι δηλωμένα στον χώρο.</p>
                </div>
            </div>

            @if (!Model.ExpectedItems.Any())
            {
                <div class="empty-state small">
                    <h3>Δεν υπάρχουν αντικείμενα για αυτόν τον χώρο</h3>
                    <p>Ίσως ο χώρος είναι κενός ή ο φάκελος δημιουργήθηκε πριν την εισαγωγή των αντικειμένων.</p>
                </div>
            }
            else
            {
                <div class="compact-list">
                    @foreach (var item in Model.ExpectedItems)
                    {
                        var isFound = Model.FoundItemIds.Contains(item.Id);

                        <article class="compact-row @(isFound ? "is-found" : "")">
                            <div>
                                <strong>@item.Name</strong>
                                <span>@item.AssetCode · @item.CategoryName</span>
                                @if (!string.IsNullOrWhiteSpace(item.SerialNumber))
                                {
                                    <small>SN: @item.SerialNumber</small>
                                }
                            </div>

                            <em>@(isFound ? "Βρέθηκε" : "Λείπει")</em>
                        </article>
                    }
                </div>
            }
        </article>

        <article class="panel">
            <div class="panel-header">
                <div>
                    <h2>Καταχωρήσεις χώρου</h2>
                    <p class="muted">Τι έχει καταγραφεί για αυτόν τον χώρο.</p>
                </div>
            </div>

            @if (!Model.SavedScans.Any())
            {
                <div class="empty-state small">
                    <h3>Δεν υπάρχουν καταχωρήσεις</h3>
                    <p>Η λίστα θα ενημερωθεί μετά από καταχώρηση από Android ή χειροκίνητα από εδώ.</p>
                </div>
            }
            else
            {
                <div class="compact-list">
                    @foreach (var scan in Model.SavedScans.OrderByDescending(x => x.ScannedAt))
                    {
                        <article class="compact-row @(scan.Status == SchoolInventoryManager.Models.AuditScanStatus.Found ? "is-found" : "has-warning")">
                            <div>
                                <strong>@scan.Name</strong>
                                <span>@scan.Code · @scan.RoomName</span>
                                <small>@scan.ScannedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>

                            <em>@scan.Status</em>
                        </article>
                    }
                </div>
            }
        </article>
    </section>

    <section class="grid two-columns">
        <article class="panel">
            <h2>Λείπουν ακόμα</h2>

            @if (!Model.MissingItems.Any())
            {
                <div class="empty-state small success">
                    <h3>Δεν λείπει κάτι</h3>
                    <p>Όλα τα αναμενόμενα αντικείμενα έχουν καταγραφεί.</p>
                </div>
            }
            else
            {
                <div class="compact-list">
                    @foreach (var item in Model.MissingItems)
                    {
                        <article class="compact-row has-warning">
                            <div>
                                <strong>@item.Name</strong>
                                <span>@item.AssetCode · @item.CategoryName</span>
                            </div>
                            <em>Λείπει</em>
                        </article>
                    }
                </div>
            }
        </article>

        <article class="panel">
            <h2>Εκτός χώρου / άγνωστα</h2>

            @if (!Model.WrongRoomScans.Any() && !Model.UnknownScans.Any())
            {
                <div class="empty-state small">
                    <h3>Δεν υπάρχουν θέματα</h3>
                    <p>Δεν έχουν καταγραφεί αντικείμενα άλλου χώρου ή άγνωστοι κωδικοί.</p>
                </div>
            }
            else
            {
                <div class="compact-list">
                    @foreach (var scan in Model.WrongRoomScans.Concat(Model.UnknownScans).OrderByDescending(x => x.ScannedAt))
                    {
                        <article class="compact-row has-warning">
                            <div>
                                <strong>@scan.Name</strong>
                                <span>@scan.Code · @scan.RoomName</span>
                            </div>
                            <em>@scan.Status</em>
                        </article>
                    }
                </div>
            }
        </article>
    </section>
}
