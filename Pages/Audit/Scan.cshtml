@page
@model SchoolInventoryManager.Pages.Audit.ScanModel

@{
    ViewData["Title"] = "Σάρωση QR";
}

<section class="page-header qr-scan-hero">
    <div>
        <span class="hero-kicker">QR απογραφής</span>
        <h1>Σάρωση QR αντικειμένου</h1>
        <p>
            Σκανάρεις QR ή πληκτρολογείς κωδικό και η εφαρμογή δείχνει αν το αντικείμενο υπάρχει στην απογραφή.
        </p>
    </div>

    <div class="actions">
        <a class="btn secondary" asp-page="/Labels/Qr">QR ετικέτες</a>
        <a class="btn secondary" asp-page="/Items/Index">Εξοπλισμός</a>
    </div>
</section>

<section class="qr-scan-grid">
    <article class="card qr-camera-card">
        <div class="section-title-row">
            <div>
                <h2>Κάμερα</h2>
                <p class="muted">Άνοιξε την κάμερα και στόχευσε το QR της ετικέτας.</p>
            </div>
        </div>

        <div class="qr-camera-box">
            <video id="qrVideo" playsinline muted></video>
            <div id="qrCameraPlaceholder" class="qr-camera-placeholder">
                <strong>Η κάμερα δεν έχει ξεκινήσει</strong>
                <span>Πάτα “Έναρξη κάμερας”. Αν ο browser την μπλοκάρει, χρησιμοποίησε χειροκίνητη αναζήτηση.</span>
            </div>
        </div>

        <div class="actions qr-camera-actions">
            <button type="button" class="btn" id="startCameraBtn">Έναρξη κάμερας</button>
            <button type="button" class="btn secondary" id="stopCameraBtn" disabled>Διακοπή</button>
        </div>

        <div id="scannerStatus" class="qr-scan-status muted">
            Έτοιμο για σάρωση.
        </div>

        <div class="qr-scan-warning">
            <strong>Σημείωση:</strong>
            Σε κινητά, η κάμερα μέσα από browser συνήθως απαιτεί HTTPS.
            Αν η εφαρμογή τρέχει ως απλό HTTP σε τοπική IP, μπορεί να χρειαστεί χειροκίνητη αναζήτηση ή μελλοντικά HTTPS.
        </div>
    </article>

    <article class="card qr-manual-card">
        <div class="section-title-row">
            <div>
                <h2>Χειροκίνητος έλεγχος</h2>
                <p class="muted">Βάλε AssetCode ή ολόκληρο QR URL.</p>
            </div>
        </div>

        <div class="form-row">
            <label for="manualCode">Κωδικός / QR URL</label>
            <input id="manualCode" placeholder="π.χ. SIM-2026-000123 ή http://server/q/SIM-2026-000123" />
        </div>

        <div class="actions">
            <button type="button" class="btn" id="manualLookupBtn">Έλεγχος</button>
            <button type="button" class="btn secondary" id="clearResultBtn">Καθαρισμός</button>
        </div>

        <div class="qr-last-scans">
            <h3>Πρόσφατες σαρώσεις</h3>
            <div id="recentScans" class="qr-recent-list">
                <span class="muted">Δεν υπάρχουν ακόμα σαρώσεις.</span>
            </div>
        </div>
    </article>
</section>

<section id="lookupResult" class="card qr-result-card qr-result-empty">
    <div class="qr-result-placeholder">
        <h2>Αποτέλεσμα σάρωσης</h2>
        <p>Σκανάρισε ή πληκτρολόγησε QR για να εμφανιστούν τα στοιχεία του αντικειμένου.</p>
    </div>
</section>

<style>
    .qr-scan-grid {
        display: grid;
        grid-template-columns: minmax(360px, 1.1fr) minmax(320px, 0.9fr);
        gap: 1rem;
        align-items: start;
    }

    .qr-camera-box {
        position: relative;
        width: 100%;
        aspect-ratio: 4 / 3;
        border: 1px solid rgba(34, 211, 238, 0.22);
        border-radius: 22px;
        overflow: hidden;
        background:
            radial-gradient(circle at center, rgba(34, 211, 238, 0.12), transparent 46%),
            rgba(2, 6, 23, 0.72);
    }

    #qrVideo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
    }

    .qr-camera-placeholder {
        position: absolute;
        inset: 0;
        display: grid;
        place-content: center;
        text-align: center;
        padding: 1.5rem;
        color: #94a3b8;
    }

    .qr-camera-placeholder strong,
    .qr-camera-placeholder span {
        display: block;
    }

    .qr-camera-placeholder strong {
        color: #f8fafc;
        margin-bottom: 0.4rem;
    }

    .qr-camera-actions {
        margin-top: 0.9rem;
    }

    .qr-scan-status {
        margin-top: 0.75rem;
        font-weight: 700;
    }

    .qr-scan-warning {
        margin-top: 0.9rem;
        border: 1px solid rgba(245, 158, 11, 0.26);
        border-radius: 16px;
        padding: 0.85rem;
        color: #fed7aa;
        background: rgba(245, 158, 11, 0.08);
        font-size: 0.88rem;
    }

    .qr-last-scans {
        margin-top: 1.25rem;
        border-top: 1px solid rgba(148, 163, 184, 0.14);
        padding-top: 1rem;
    }

    .qr-last-scans h3 {
        color: #f8fafc;
        margin: 0 0 0.75rem;
        font-size: 1rem;
    }

    .qr-recent-list {
        display: grid;
        gap: 0.5rem;
    }

    .qr-recent-item {
        border: 1px solid rgba(148, 163, 184, 0.14);
        border-radius: 14px;
        padding: 0.65rem 0.75rem;
        background: rgba(2, 6, 23, 0.32);
        color: inherit;
        text-decoration: none;
    }

    .qr-recent-item strong,
    .qr-recent-item span {
        display: block;
    }

    .qr-recent-item strong {
        color: #f8fafc;
        font-size: 0.9rem;
    }

    .qr-recent-item span {
        color: #94a3b8;
        font-size: 0.78rem;
        margin-top: 0.15rem;
    }

    .qr-result-card {
        margin-top: 1rem;
    }

    .qr-result-placeholder {
        text-align: center;
        color: #94a3b8;
        padding: 1.25rem;
    }

    .qr-result-placeholder h2 {
        color: #f8fafc;
        margin: 0 0 0.35rem;
    }

    .qr-result-found {
        border-color: rgba(34, 197, 94, 0.28);
        background:
            radial-gradient(circle at top left, rgba(34, 197, 94, 0.10), transparent 34%),
            rgba(15, 23, 42, 0.76);
    }

    .qr-result-not-found {
        border-color: rgba(248, 113, 113, 0.28);
        background:
            radial-gradient(circle at top left, rgba(248, 113, 113, 0.10), transparent 34%),
            rgba(15, 23, 42, 0.76);
    }

    .qr-result-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: start;
        border-bottom: 1px solid rgba(148, 163, 184, 0.14);
        padding-bottom: 1rem;
        margin-bottom: 1rem;
    }

    .qr-result-header h2 {
        color: #f8fafc;
        margin: 0 0 0.35rem;
    }

    .qr-result-header p {
        color: #94a3b8;
        margin: 0;
    }

    .qr-result-code {
        color: #67e8f9;
        font-weight: 900;
        white-space: nowrap;
    }

    .qr-result-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .qr-result-grid div {
        border: 1px solid rgba(148, 163, 184, 0.14);
        border-radius: 16px;
        padding: 0.8rem;
        background: rgba(2, 6, 23, 0.28);
    }

    .qr-result-grid span,
    .qr-result-grid strong {
        display: block;
    }

    .qr-result-grid span {
        color: #94a3b8;
        font-size: 0.76rem;
        font-weight: 800;
    }

    .qr-result-grid strong {
        color: #f8fafc;
        margin-top: 0.25rem;
        overflow-wrap: anywhere;
    }

    @@media (max-width: 900px) {
        .qr-scan-grid,
        .qr-result-grid {
            grid-template-columns: 1fr;
        }

        .qr-result-header {
            display: block;
        }

        .qr-result-code {
            display: block;
            margin-top: 0.5rem;
        }
    }
</style>

@section Scripts {
<script>
    let qrStream = null;
    let qrDetector = null;
    let qrScanTimer = null;
    let lastScannedText = "";
    let lastScannedAt = 0;

    const video = document.getElementById("qrVideo");
    const placeholder = document.getElementById("qrCameraPlaceholder");
    const scannerStatus = document.getElementById("scannerStatus");
    const startBtn = document.getElementById("startCameraBtn");
    const stopBtn = document.getElementById("stopCameraBtn");
    const manualInput = document.getElementById("manualCode");
    const manualBtn = document.getElementById("manualLookupBtn");
    const clearBtn = document.getElementById("clearResultBtn");
    const resultBox = document.getElementById("lookupResult");
    const recentScans = document.getElementById("recentScans");

    function setStatus(message) {
        scannerStatus.textContent = message;
    }

    function hasBarcodeDetector() {
        return "BarcodeDetector" in window;
    }

    async function startCamera() {
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
            setStatus("Ο browser δεν υποστηρίζει πρόσβαση στην κάμερα.");
            return;
        }

        if (!hasBarcodeDetector()) {
            setStatus("Ο browser δεν υποστηρίζει BarcodeDetector. Χρησιμοποίησε χειροκίνητη αναζήτηση ή εξωτερικό QR scanner.");
            return;
        }

        try {
            qrDetector = new BarcodeDetector({ formats: ["qr_code"] });

            qrStream = await navigator.mediaDevices.getUserMedia({
                video: {
                    facingMode: { ideal: "environment" },
                    width: { ideal: 1280 },
                    height: { ideal: 720 }
                },
                audio: false
            });

            video.srcObject = qrStream;
            video.style.display = "block";
            placeholder.style.display = "none";

            await video.play();

            startBtn.disabled = true;
            stopBtn.disabled = false;
            setStatus("Η κάμερα λειτουργεί. Στόχευσε το QR.");

            scanLoop();
        } catch (error) {
            console.error(error);
            setStatus("Δεν μπόρεσε να ανοίξει η κάμερα. Σε κινητό με HTTP/IP ίσως χρειάζεται HTTPS.");
        }
    }

    function stopCamera() {
        if (qrScanTimer) {
            clearTimeout(qrScanTimer);
            qrScanTimer = null;
        }

        if (qrStream) {
            qrStream.getTracks().forEach(track => track.stop());
            qrStream = null;
        }

        video.pause();
        video.srcObject = null;
        video.style.display = "none";
        placeholder.style.display = "grid";

        startBtn.disabled = false;
        stopBtn.disabled = true;
        setStatus("Η κάμερα σταμάτησε.");
    }

    async function scanLoop() {
        if (!qrStream || !qrDetector) {
            return;
        }

        try {
            const barcodes = await qrDetector.detect(video);

            if (barcodes && barcodes.length > 0) {
                const rawValue = barcodes[0].rawValue;

                const now = Date.now();
                if (rawValue && (rawValue !== lastScannedText || now - lastScannedAt > 3000)) {
                    lastScannedText = rawValue;
                    lastScannedAt = now;
                    setStatus("QR εντοπίστηκε. Έλεγχος...");
                    await lookupCode(rawValue);
                }
            }
        } catch (error) {
            console.error(error);
            setStatus("Σφάλμα κατά τη σάρωση. Δοκίμασε ξανά.");
        }

        qrScanTimer = setTimeout(scanLoop, 450);
    }

    async function lookupCode(value) {
        const code = (value || "").trim();

        if (!code) {
            renderNotFound("Δεν δόθηκε κωδικός.");
            return;
        }

        try {
            const url = `?handler=Lookup&code=${encodeURIComponent(code)}`;
            const response = await fetch(url, {
                headers: { "Accept": "application/json" }
            });

            if (!response.ok) {
                renderNotFound("Δεν μπόρεσε να γίνει έλεγχος του QR.");
                return;
            }

            const data = await response.json();

            if (data.found) {
                renderFound(data);
                addRecent(data);
                setStatus("Το αντικείμενο βρέθηκε.");
            } else {
                renderNotFound(data.message || "Το QR δεν βρέθηκε στην απογραφή.");
                setStatus("Δεν βρέθηκε αντικείμενο.");
            }
        } catch (error) {
            console.error(error);
            renderNotFound("Σφάλμα κατά τον έλεγχο του QR.");
            setStatus("Σφάλμα κατά τον έλεγχο.");
        }
    }

    function renderFound(data) {
        resultBox.className = "card qr-result-card qr-result-found";
        resultBox.innerHTML = `
            <div class="qr-result-header">
                <div>
                    <h2>${escapeHtml(data.name)}</h2>
                    <p>${escapeHtml(data.message || "Το αντικείμενο βρέθηκε.")}</p>
                </div>
                <div class="qr-result-code">${escapeHtml(data.code)}</div>
            </div>

            <div class="qr-result-grid">
                <div><span>Χώρος</span><strong>${escapeHtml(data.roomName || "-")}</strong></div>
                <div><span>Κατηγορία</span><strong>${escapeHtml(data.categoryName || "-")}</strong></div>
                <div><span>Κατάσταση</span><strong>${escapeHtml(data.conditionText || "-")}</strong></div>
                <div><span>Ποσότητα</span><strong>${escapeHtml(String(data.quantity || 0))}</strong></div>
                <div><span>Μάρκα / μοντέλο</span><strong>${escapeHtml(data.brandModel || "-")}</strong></div>
                <div><span>Serial</span><strong>${escapeHtml(data.serialNumber || "-")}</strong></div>
                <div><span>Ενεργό</span><strong>${data.isActive ? "Ναι" : "Όχι"}</strong></div>
                <div><span>ID</span><strong>${escapeHtml(String(data.itemId || "-"))}</strong></div>
            </div>

            <div class="actions">
                <a class="btn" href="${escapeAttribute(data.itemCardUrl || "#")}" target="_blank">Άνοιγμα καρτέλας</a>
                <a class="btn secondary" href="${escapeAttribute(data.editUrl || "#")}">Επεξεργασία</a>
            </div>
        `;
    }

    function renderNotFound(message) {
        resultBox.className = "card qr-result-card qr-result-not-found";
        resultBox.innerHTML = `
            <div class="qr-result-header">
                <div>
                    <h2>Δεν βρέθηκε αντικείμενο</h2>
                    <p>${escapeHtml(message)}</p>
                </div>
            </div>
        `;
    }

    function addRecent(data) {
        const empty = recentScans.querySelector(".muted");
        if (empty) {
            recentScans.innerHTML = "";
        }

        const link = document.createElement("a");
        link.className = "qr-recent-item";
        link.href = data.itemCardUrl || "#";
        link.target = "_blank";
        link.innerHTML = `
            <strong>${escapeHtml(data.name)}</strong>
            <span>${escapeHtml(data.code)} · ${escapeHtml(data.roomName || "-")}</span>
        `;

        recentScans.prepend(link);

        const items = recentScans.querySelectorAll(".qr-recent-item");
        items.forEach((item, index) => {
            if (index >= 8) {
                item.remove();
            }
        });
    }

    function clearResult() {
        resultBox.className = "card qr-result-card qr-result-empty";
        resultBox.innerHTML = `
            <div class="qr-result-placeholder">
                <h2>Αποτέλεσμα σάρωσης</h2>
                <p>Σκανάρισε ή πληκτρολόγησε QR για να εμφανιστούν τα στοιχεία του αντικειμένου.</p>
            </div>
        `;
        manualInput.value = "";
        setStatus("Έτοιμο για σάρωση.");
    }

    function escapeHtml(value) {
        return String(value || "")
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#039;");
    }

    function escapeAttribute(value) {
        return escapeHtml(value);
    }

    startBtn.addEventListener("click", startCamera);
    stopBtn.addEventListener("click", stopCamera);

    manualBtn.addEventListener("click", function () {
        lookupCode(manualInput.value);
    });

    manualInput.addEventListener("keydown", function (event) {
        if (event.key === "Enter") {
            event.preventDefault();
            lookupCode(manualInput.value);
        }
    });

    clearBtn.addEventListener("click", clearResult);
</script>
}
