    }

    .sim47-room-flow strong {
        color: #f8fafc;
    }

    .sim47-room-flow span {
        color: #94a3b8;
        font-size: .78rem;
    }

    .sim47-signal-stack {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: .5rem;
        margin-bottom: .8rem;
    }

    .sim47-signal-stack div {
        border-radius: 16px;
        padding: .65rem;
        border: 1px solid rgba(148, 163, 184, .12);
        background: rgba(2, 6, 23, .34);
    }

    .sim47-signal-stack strong,
    .sim47-signal-stack span {
        display: block;
    }

    .sim47-signal-stack strong {
        color: #f8fafc;
        font-size: 1.15rem;
        line-height: 1;
    }

    .sim47-signal-stack span {
        color: #94a3b8;
        font-size: .68rem;
        margin-top: .3rem;
    }

    .sim47-feed-list a {
        border-radius: 16px;
        padding: .7rem;
    }

    .sim47-empty {
        color: #94a3b8;
        border: 1px dashed rgba(148, 163, 184, .20);
        border-radius: 16px;
        padding: .9rem;
        background: rgba(2, 6, 23, .22);
    }

    @@media (min-width: 1900px) {
        .sim47-cockpit {
            grid-template-columns: minmax(300px, .72fr) minmax(720px, 2.5fr) minmax(360px, .9fr);
        }

        .sim47-launch-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 1380px) {
        .sim47-cockpit {
            grid-template-columns: minmax(240px, .85fr) minmax(0, 2fr);
        }

        .sim47-side-feed {
            grid-column: 1 / -1;
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 1050px) {
        .sim47-topline,
        .sim47-cockpit,
        .sim47-stage-grid,
        .sim47-wide-grid,
        .sim47-map-content,
        .sim47-side-feed {
            grid-template-columns: 1fr;
        }

        .sim47-top-actions {
            justify-content: flex-start;
        }

        .sim47-metrics-ribbon {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 640px) {
        .sim47-page {
            --gutter: .65rem;
            width: calc(100vw - (var(--gutter) * 2));
        }

        .sim47-metrics-ribbon,
        .sim47-launch-grid,
        .sim47-signal-stack {
            grid-template-columns: 1fr;
        }

        .sim47-top-actions .sim47-btn {
            width: 100%;
        }
    }
</style>

@functions {
    private static string IconForCategory(string? category)
    {
        var name = (category ?? string.Empty).ToLowerInvariant();

        if (name.Contains("υπολογ") || name.Contains("η/υ") || name.Contains("pc") || name.Contains("computer"))
        {
            return "🖥";
        }

        if (name.Contains("laptop") || name.Contains("φορη"))
        {
            return "💻";
        }

        if (name.Contains("οθον") || name.Contains("τηλε"))
        {
            return "🖵";
        }

        if (name.Contains("δικτυ") || name.Contains("router") || name.Contains("switch"))
        {
            return "⌁";
        }

        if (name.Contains("εκτυπ") || name.Contains("printer"))
        {
            return "▤";
        }

        if (name.Contains("tablet"))
        {
            return "▯";
        }

        if (name.Contains("διαδρασ"))
        {
            return "✦";
        }

        return "◆";
    }
}
