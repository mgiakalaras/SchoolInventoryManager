@page
@model SchoolInventoryManager.Pages.Labels.MobileFindingsModel

@{
    ViewData["Title"] = "QR νέων ευρημάτων";
    var labelPages = Model.Items
        .Select((item, index) => new { item, index })
        .GroupBy(x => x.index / 21)
        .Select(g => g.Select(x => x.item).ToList())
        .ToList();
}

<style>
    .mobile-labels-page {
        max-width: 1180px;
        margin: 0 auto;
        padding-bottom: 3rem;
    }

    .mobile-labels-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: center;
        padding: 1.35rem;
        border: 1px solid rgba(34, 211, 238, .22);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .14), transparent 38%),
            linear-gradient(135deg, rgba(15, 23, 42, .98), rgba(17, 24, 39, .92));
        box-shadow: 0 18px 42px rgba(0, 0, 0, .28);
        margin-bottom: 1rem;
    }

    .mobile-labels-hero h1,
    .mobile-labels-card h2,
    .mobile-labels-card h3 {
        margin: 0;
    }

    .mobile-labels-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .55rem;
        justify-content: flex-end;
    }

    .mobile-labels-badge {
        display: inline-flex;
        width: fit-content;
        padding: .25rem .55rem;
        border-radius: 999px;
        border: 1px solid rgba(34, 211, 238, .32);
        color: #a5f3fc;
        background: rgba(8, 47, 73, .42);
        font-weight: 800;
        font-size: .72rem;
        letter-spacing: .03em;
        text-transform: uppercase;
        margin-bottom: .65rem;
    }

    .mobile-labels-card {
        border: 1px solid rgba(148, 163, 184, .16);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .06), transparent 40%),
            rgba(15, 23, 42, .82);
        padding: 1rem;
        box-shadow: 0 14px 34px rgba(0, 0, 0, .22);
        margin-bottom: 1rem;
    }

    .mobile-labels-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: .75rem;
        margin-bottom: 1rem;
    }

    .mobile-labels-stat {
        padding: .85rem;
        border: 1px solid rgba(148, 163, 184, .15);
        border-radius: 16px;
        background: rgba(2, 6, 23, .36);
    }

    .mobile-labels-stat span {
        display: block;
        color: #94a3b8;
        font-size: .8rem;
        margin-bottom: .25rem;
    }

    .mobile-labels-stat strong {
        display: block;
        font-size: 1.35rem;
        line-height: 1;
    }

    .mobile-labels-filter {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) minmax(220px, 320px) auto auto;
        gap: .75rem;
        align-items: end;
    }

    .mobile-labels-filter label span {
        display: block;
        font-weight: 800;
        margin-bottom: .35rem;
    }

    .mobile-labels-filter input[type="text"],
    .mobile-labels-filter select {
        width: 100%;
        min-height: 42px;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, .22);
        background: rgba(2, 6, 23, .45);
        color: #e5eefb;
        padding: .65rem .75rem;
    }

    .mobile-labels-check {
        display: flex;
        gap: .45rem;
        align-items: center;
        min-height: 42px;
        color: #cbd5e1;
    }

    .mobile-labels-room-group {
        margin-top: 1rem;
    }

    .mobile-labels-room-title {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: .85rem 1rem;
        border-radius: 16px;
        border: 1px solid rgba(34, 211, 238, .18);
        background: rgba(8, 47, 73, .28);
        margin-bottom: .65rem;
    }

    .mobile-labels-list {
        display: grid;
        gap: .6rem;
    }

    .mobile-labels-row {
        display: grid;
        grid-template-columns: auto 70px minmax(0, 1fr) auto;
        gap: .85rem;
        align-items: center;
        border: 1px solid rgba(148, 163, 184, .13);
        border-radius: 16px;
        background: rgba(2, 6, 23, .33);
        padding: .8rem;
    }

    .mobile-labels-row img {
        width: 58px;
        height: 58px;
        border-radius: 10px;
        background: white;
        padding: 4px;
    }

    .mobile-labels-row strong,
    .mobile-labels-row span,
    .mobile-labels-row small {
        display: block;
    }

    .mobile-labels-row span,
    .mobile-labels-row small {
        color: #94a3b8;
    }

    .mobile-labels-row-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(90px, 1fr));
        gap: .45rem;
        min-width: 190px;
    }

    .mobile-labels-row-actions .btn {
        width: 100%;
        text-align: center;
        justify-content: center;
        white-space: nowrap;
    }

    .mobile-labels-empty {
        text-align: center;
        padding: 2rem;
        border: 1px dashed rgba(148, 163, 184, .22);
        border-radius: 18px;
        color: #94a3b8;
    }

    .labels-print-area {
        display: none;
    }

    @@media print {
        body * {
            visibility: hidden !important;
        }

        .labels-print-area,
        .labels-print-area * {
            visibility: visible !important;
        }

        .labels-print-area {
            display: block !important;
            position: absolute;
            left: 0;
            top: -18mm;
            width: 210mm;
            margin: 0;
            padding: 0;
        }

        @@page {
            size: A4;
            margin: 0;
        }

        .print-label-sheet {
            width: 210mm;
            height: 297mm;
            display: grid;
            grid-template-columns: repeat(3, 70mm);
            grid-template-rows: repeat(7, 42.3mm);
            grid-auto-flow: column;
            page-break-after: always;
            break-after: page;
            margin: 0;
            padding: 0;
        }

        .print-label {
            width: 70mm;
            height: 42.3mm;
            box-sizing: border-box;
            padding: 3.2mm 4mm;
            overflow: hidden;
            display: grid;
            grid-template-columns: 21mm 1fr;
            gap: 2.5mm;
            align-items: center;
            color: #000 !important;
            background: #fff !important;
            font-family: Arial, sans-serif;
        }

        .print-label img {
            width: 20mm;
            height: 20mm;
        }

        .print-label strong {
            display: block;
            font-size: 8.5pt;
            line-height: 1.05;
            margin-bottom: 1mm;
        }

        .print-label span,
        .print-label small {
            display: block;
            font-size: 6.8pt;
            line-height: 1.05;
        }

        .print-label .room {
            font-weight: 700;
        }

        .screen-only {
            display: none !important;
        }
    }

    @@media (max-width: 900px) {
        .mobile-labels-hero,
        .mobile-labels-filter,
        .mobile-labels-row {
            grid-template-columns: 1fr;
        }

        .mobile-labels-actions {
            justify-content: flex-start;
        }

        .mobile-labels-stats {
            grid-template-columns: 1fr;
        }

        .mobile-labels-row-actions {
            min-width: 0;
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="mobile-labels-page screen-only">
    <section class="mobile-labels-hero">
        <div>
            <span class="mobile-labels-badge">QR labels</span>
            <h1>QR νέων ευρημάτων</h1>
            <p class="muted">
                Εκτύπωση QR μόνο για αντικείμενα που προστέθηκαν από κινητό/tablet κατά την απογραφή.
            </p>
        </div>

        <div class="mobile-labels-actions">
            <button type="button" class="btn primary" onclick="printSelectedMobileFindingLabels()">Εκτύπωση επιλεγμένων</button>
            <button type="button" class="btn secondary" onclick="selectAllMobileFindingLabels(true)">Επιλογή όλων</button>
            <button type="button" class="btn secondary" onclick="selectAllMobileFindingLabels(false)">Καμία επιλογή</button>
            <a class="btn secondary" asp-page="/InventoryAudits/MobileFindings">Νέα ευρήματα</a>
        </div>
    </section>

    <section class="mobile-labels-card">
        <div class="mobile-labels-stats">
            <article class="mobile-labels-stat">
                <span>Ετικέτες</span>
                <strong>@Model.TotalRows</strong>
            </article>

            <article class="mobile-labels-stat">
                <span>Χώροι</span>
                <strong>@Model.RoomsCount</strong>
            </article>

            <article class="mobile-labels-stat">
                <span>Base URL</span>
                <strong style="font-size:.95rem;">@Model.BaseUrl</strong>
            </article>
        </div>

        <form method="get" class="mobile-labels-filter">
            <label>
                <span>Αναζήτηση</span>
                <input asp-for="Search" type="text" placeholder="όνομα, κωδικός, serial..." />
            </label>

            <label>
                <span>Χώρος</span>
                <select asp-for="RoomId" asp-items="Model.Rooms">
                    <option value="">Όλοι οι χώροι</option>
                </select>
            </label>

            <label class="mobile-labels-check">
                <input asp-for="IncludeInactive" />
                <span>Και ανενεργά</span>
            </label>

            <button type="submit" class="btn primary">Φίλτρο</button>
        </form>
    </section>

    <section class="mobile-labels-card">
        <h2>Αντικείμενα για εκτύπωση</h2>
        <p class="muted">
            Η εκτύπωση είναι σε A4 / 21 ετικέτες ανά φύλλο / 3 στήλες x 7 σειρές.
            Τα αντικείμενα είναι ήδη ομαδοποιημένα ανά αίθουσα για να μην ψάχνεσαι στο κόλλημα των QR.
        </p>

        @if (!Model.Items.Any())
        {
            <div class="mobile-labels-empty">
                <h3>Δεν υπάρχουν νέα ευρήματα για QR</h3>
                <p>Πρόσθεσε νέο αντικείμενο από την Android εφαρμογή ή καθάρισε τα φίλτρα.</p>
            </div>
        }
        else
        {
            @foreach (var group in Model.Items.GroupBy(x => x.RoomName).OrderBy(x => x.Key))
            {
                <div class="mobile-labels-room-group">
                    <div class="mobile-labels-room-title">
                        <strong>@group.Key</strong>
                        <span class="muted">@group.Count() ετικέτες</span>
                    </div>

                    <div class="mobile-labels-list">
                        @foreach (var item in group)
                        {
                            <article class="mobile-labels-row">
                                <input type="checkbox" class="mobile-finding-label-checkbox" value="@item.Id" checked />

                                <img src="@item.QrImageDataUrl" alt="QR @item.AssetCode" />

                                <div>
                                    <strong>@item.Name</strong>
                                    <span>@item.AssetCode · @item.CategoryName</span>
                                    @if (!string.IsNullOrWhiteSpace(item.BrandModel))
                                    {
                                        <small>@item.BrandModel</small>
                                    }
                                    <small>SN: @(string.IsNullOrWhiteSpace(item.SerialNumber) ? "-" : item.SerialNumber)</small>
                                </div>

                                <div class="mobile-labels-row-actions">
                                    <a class="btn secondary" asp-page="/Items/Edit" asp-route-id="@item.Id">Edit</a>
                                    <a class="btn secondary" asp-page="/Items/Qr" asp-route-code="@item.AssetCode">QR</a>
                                </div>
                            </article>
                        }
                    </div>
                </div>
            }
        }
    </section>
</div>

<div class="labels-print-area" aria-hidden="true">
    @foreach (var pageItems in labelPages)
    {
        <section class="print-label-sheet">
            @foreach (var item in pageItems)
            {
                <article class="print-label" data-label-id="@item.Id">
                    <img src="@item.QrImageDataUrl" alt="QR @item.AssetCode" />
                    <div>
                        <strong>@item.AssetCode</strong>
                        <span>@item.Name</span>
                        <span class="room">@item.RoomName</span>
                        <small>Απογραφή: @item.InventoryDateText</small>
                        @if (!string.IsNullOrWhiteSpace(item.SerialNumber))
                        {
                            <small>SN: @item.SerialNumber</small>
                        }
                    </div>
                </article>
            }
        </section>
    }
</div>

<script>
    function selectAllMobileFindingLabels(checked) {
        document.querySelectorAll('.mobile-finding-label-checkbox').forEach(function (box) {
            box.checked = checked;
        });
    }

    function printSelectedMobileFindingLabels() {
        const selected = new Set(
            Array.from(document.querySelectorAll('.mobile-finding-label-checkbox:checked'))
                .map(x => x.value)
        );

        document.querySelectorAll('.print-label').forEach(function (label) {
            const id = label.getAttribute('data-label-id');
            label.style.display = selected.has(id) ? '' : 'none';
        });

        window.print();

        setTimeout(function () {
            document.querySelectorAll('.print-label').forEach(function (label) {
                label.style.display = '';
            });
        }, 500);
    }
</script>
