@page
@model SchoolInventoryManager.Pages.Scanner.IndexModel

@{
    ViewData["Title"] = "Εφαρμογή Scanner";
}

<section class="scanner-landing-hero">
    <div class="scanner-hero-copy">
        <span class="hero-kicker">Native Android scanner</span>
        <h1>Η σάρωση QR περνάει στην εφαρμογή Android.</h1>
        <p>
            Το web app μένει για διαχείριση, φακέλους απογραφής, αναφορές και εκτυπώσεις.
            Η κάμερα και η γρήγορη καταγραφή θα γίνονται από native εφαρμογή σε κινητό ή tablet.
        </p>

        <div class="scanner-hero-actions">
            @if (Model.ApkExists)
            {
                <a class="btn scanner-download-primary" href="@Model.ApkDownloadUrl" download>
                    Λήψη Android εφαρμογής
                </a>
            }
            else
            {
                <span class="btn scanner-download-primary disabled" aria-disabled="true">
                    Η εφαρμογή Android ετοιμάζεται
                </span>
            }

            <a class="btn secondary" asp-page="/Help/Index">Άνοιγμα βοήθειας</a>
            <a class="btn secondary" asp-page="/InventoryAudits/Index">Φάκελοι απογραφής</a>
        </div>

        <div class="scanner-release-note">
            <strong>Κατάσταση:</strong>
            <span>
                @(Model.ApkExists
                    ? $"Διαθέσιμο APK · {Model.ApkSizeText}"
                    : "Το APK θα προστεθεί στο επόμενο βήμα, αφού δημιουργηθεί το Android project.")
            </span>
        </div>
    </div>

    <div class="scanner-hero-visual">
        <img src="~/assets/mobile-scanner/scanner-logo-dark.svg" alt="School Inventory Scanner" />
    </div>
</section>

<section class="scanner-info-grid">
    <article class="scanner-card">
        <img src="~/assets/icons/android-phone.svg" alt="" />
        <h2>Γιατί native εφαρμογή;</h2>
        <p>
            Οι mobile browsers μπλοκάρουν συχνά την κάμερα σε απλό HTTP.
            Η native εφαρμογή ζητά άδεια κάμερας από το Android και σκανάρει κανονικά.
        </p>
    </article>

    <article class="scanner-card">
        <img src="~/assets/icons/sync-cloud.svg" alt="" />
        <h2>Μιλάει με τον server</h2>
        <p>
            Η εφαρμογή θα συνδέεται με το School Inventory Manager και θα στέλνει τις σαρώσεις στον σωστό φάκελο και χώρο.
        </p>
    </article>

    <article class="scanner-card">
        <img src="~/assets/icons/help-book.svg" alt="" />
        <h2>Φιλική χρήση</h2>
        <p>
            Επιλογή φακέλου, επιλογή χώρου, σάρωση QR, αποτέλεσμα. Λίγα βήματα, μεγάλα κουμπιά, καθαρό feedback.
        </p>
    </article>
</section>

<section class="scanner-workflow-card">
    <div>
        <h2>Ροή εργασίας</h2>
        <p>
            Η διαδικασία απογραφής παραμένει οργανωμένη γύρω από τους φακέλους απογραφής του web app.
        </p>
    </div>
    <img src="~/assets/help/android-workflow-dark.svg" alt="Ροή native σάρωσης" />
</section>

<section class="scanner-download-card">
    <div class="scanner-download-qr">
        <img src="~/assets/help/mobile-scanner-download-card.svg" alt="Λήψη εφαρμογής scanner" />
    </div>

    <div class="scanner-download-steps">
        <h2>Πώς θα γίνεται η εγκατάσταση</h2>
        <ol>
            <li>Ανοίγεις αυτή τη σελίδα από κινητό ή tablet.</li>
            <li>Πατάς <strong>Λήψη Android εφαρμογής</strong>.</li>
            <li>Εγκαθιστάς το APK.</li>
            <li>Ορίζεις τη διεύθυνση server, π.χ. <strong>http://172.26.0.1:5148</strong>.</li>
            <li>Επιλέγεις φάκελο/χώρο και ξεκινάς σάρωση.</li>
        </ol>

        <div class="scanner-warning">
            <strong>Σημαντικό:</strong>
            Μέχρι να δημιουργηθεί το Android app, η λήψη θα φαίνεται ως μη διαθέσιμη.
            Η σελίδα είναι έτοιμη για να κουμπώσει το APK.
        </div>
    </div>
</section>

<style>
    .scanner-landing-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
        gap: 1.2rem;
        align-items: stretch;
        margin-bottom: 1rem;
    }

    .scanner-hero-copy,
    .scanner-hero-visual,
    .scanner-card,
    .scanner-workflow-card,
    .scanner-download-card {
        border: 1px solid rgba(34, 211, 238, 0.18);
        border-radius: 28px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, 0.12), transparent 35%),
            rgba(15, 23, 42, 0.78);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.22);
    }

    .scanner-hero-copy {
        padding: clamp(1.25rem, 3vw, 2rem);
    }

    .scanner-hero-copy h1 {
        color: #f8fafc;
        font-size: clamp(2rem, 4vw, 4.1rem);
        line-height: 0.98;
        letter-spacing: -0.05em;
        margin: 0.5rem 0 0.8rem;
        max-width: 900px;
    }

    .scanner-hero-copy p {
        color: #cbd5e1;
        font-size: 1.08rem;
        line-height: 1.6;
        max-width: 780px;
        margin: 0;
    }

    .scanner-hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.2rem;
    }

    .scanner-download-primary {
        background: linear-gradient(135deg, #22d3ee, #34d399);
        color: #06121f !important;
        border: 0;
        box-shadow: 0 18px 38px rgba(34, 211, 238, 0.20);
    }

    .scanner-download-primary.disabled {
        opacity: 0.72;
        cursor: not-allowed;
        filter: grayscale(0.15);
    }

    .scanner-release-note {
        margin-top: 1rem;
        display: inline-flex;
        gap: 0.45rem;
        align-items: center;
        border: 1px solid rgba(245, 158, 11, 0.24);
        border-radius: 999px;
        padding: 0.55rem 0.75rem;
        background: rgba(245, 158, 11, 0.08);
        color: #fed7aa;
        font-size: 0.92rem;
    }

    .scanner-hero-visual {
        display: grid;
        place-items: center;
        padding: 1.1rem;
        overflow: hidden;
    }

    .scanner-hero-visual img {
        width: min(100%, 560px);
        height: auto;
        display: block;
    }

    .scanner-info-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .scanner-card {
        padding: 1.2rem;
        min-height: 220px;
    }

    .scanner-card img {
        width: 64px;
        height: 64px;
        margin-bottom: 0.8rem;
    }

    .scanner-card h2,
    .scanner-workflow-card h2,
    .scanner-download-steps h2 {
        color: #f8fafc;
        margin: 0 0 0.55rem;
    }

    .scanner-card p,
    .scanner-workflow-card p,
    .scanner-download-steps li {
        color: #cbd5e1;
        line-height: 1.55;
    }

    .scanner-workflow-card {
        padding: 1.2rem;
        margin-bottom: 1rem;
    }

    .scanner-workflow-card img,
    .scanner-download-qr img {
        width: 100%;
        height: auto;
        border-radius: 20px;
        display: block;
    }

    .scanner-download-card {
        display: grid;
        grid-template-columns: minmax(320px, 1fr) minmax(320px, 0.75fr);
        gap: 1rem;
        padding: 1.2rem;
    }

    .scanner-download-steps ol {
        margin: 0;
        padding-left: 1.2rem;
    }

    .scanner-download-steps li + li {
        margin-top: 0.55rem;
    }

    .scanner-warning {
        margin-top: 1rem;
        border: 1px solid rgba(245, 158, 11, 0.26);
        border-radius: 18px;
        padding: 0.9rem;
        color: #fed7aa;
        background: rgba(245, 158, 11, 0.08);
    }

    @@media (max-width: 980px) {
        .scanner-landing-hero,
        .scanner-info-grid,
        .scanner-download-card {
            grid-template-columns: 1fr;
        }

        .scanner-hero-copy h1 {
            font-size: 2.3rem;
        }
    }
</style>
