@page
@model SchoolInventoryManager.Pages.InventoryAudits.IndexModel

@{
    ViewData["Title"] = "Φάκελοι απογραφής";
}

<style>
    .audit-index-page {
        max-width: 1180px;
        margin: 0 auto;
        padding-bottom: 3rem;
    }

    .audit-index-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: center;
        padding: 1.35rem;
        border: 1px solid rgba(34, 211, 238, .22);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .14), transparent 38%),
            linear-gradient(135deg, rgba(15, 23, 42, .98), rgba(17, 24, 39, .92));
        box-shadow: 0 18px 42px rgba(0, 0, 0, .28);
        margin-bottom: 1rem;
    }

    .audit-index-hero h1 {
        margin: 0;
    }

    .audit-index-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .55rem;
        justify-content: flex-end;
    }

    .audit-index-card {
        border: 1px solid rgba(148, 163, 184, .16);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .06), transparent 40%),
            rgba(15, 23, 42, .82);
        padding: 1rem;
        box-shadow: 0 14px 34px rgba(0, 0, 0, .22);
        margin-bottom: 1rem;
    }

    .audit-index-badge {
        display: inline-flex;
        width: fit-content;
        padding: .25rem .55rem;
        border-radius: 999px;
        border: 1px solid rgba(34, 211, 238, .32);
        color: #a5f3fc;
        background: rgba(8, 47, 73, .42);
        font-weight: 800;
        font-size: .72rem;
        letter-spacing: .03em;
        text-transform: uppercase;
        margin-bottom: .65rem;
    }

    .audit-index-table-wrap {
        overflow-x: auto;
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, .14);
    }

    .audit-index-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 900px;
    }

    .audit-index-table th,
    .audit-index-table td {
        padding: .85rem;
        border-bottom: 1px solid rgba(148, 163, 184, .12);
        text-align: left;
        vertical-align: top;
    }

    .audit-index-table th {
        color: #e5eefb;
        background: rgba(8, 47, 73, .36);
    }

    .audit-index-table td {
        color: #cbd5e1;
    }

    .audit-index-table tr:last-child td {
        border-bottom: 0;
    }

    .audit-index-status {
        display: inline-flex;
        padding: .25rem .55rem;
        border-radius: 999px;
        font-weight: 800;
        font-size: .75rem;
        background: rgba(245, 158, 11, .15);
        color: #fcd34d;
        border: 1px solid rgba(245, 158, 11, .35);
    }

    .audit-index-status.final {
        background: rgba(52, 211, 153, .15);
        color: #86efac;
        border-color: rgba(52, 211, 153, .35);
    }

    .audit-index-table td.audit-index-actions-cell {
        min-width: 260px;
        width: 280px;
    }

    .audit-index-row-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .5rem;
        align-items: stretch;
    }

    .audit-index-row-actions .btn,
    .audit-index-row-actions button {
        width: 100%;
        min-height: 40px;
        justify-content: center;
        text-align: center;
        margin: 0;
        white-space: nowrap;
    }

    .audit-index-row-actions .audit-index-open-action {
        grid-column: 1 / -1;
    }

    .audit-index-inline-form {
        display: block;
        margin: 0;
    }

    .audit-index-danger-zone {
        display: contents;
    }

    @@media (max-width: 980px) {
        .audit-index-table td.audit-index-actions-cell {
            min-width: 220px;
            width: 240px;
        }

        .audit-index-row-actions {
            grid-template-columns: 1fr;
        }

        .audit-index-row-actions .audit-index-open-action {
            grid-column: auto;
        }

        .audit-index-danger-zone {
            display: grid;
            gap: .5rem;
        }
    }

    .audit-index-empty {
        text-align: center;
        padding: 2rem;
        border: 1px dashed rgba(148, 163, 184, .22);
        border-radius: 18px;
        color: #94a3b8;
    }

    @@media (max-width: 900px) {
        .audit-index-hero {
            grid-template-columns: 1fr;
        }

        .audit-index-actions {
            justify-content: flex-start;
        }
    }
</style>

<div class="audit-index-page">
    <section class="audit-index-hero">
        <div>
            <span class="audit-index-badge">Οργανωμένη απογραφή</span>
            <h1>Φάκελοι απογραφής</h1>
            <p class="muted">
                Δημιουργείς φάκελο, κάνεις απογραφή ανά χώρο από Android ή χειροκίνητα από web και στο τέλος οριστικοποιείς.
            </p>
        </div>

        <div class="audit-index-actions">
            <a class="btn primary" asp-page="/InventoryAudits/Create">Νέος φάκελος απογραφής</a>
            <a class="btn secondary" asp-page="/Audit/Room">Χειροκίνητος έλεγχος χώρου</a>
            <a class="btn secondary" asp-page="/Scanner/Index">Android Scanner</a>
        </div>
    </section>

    @if (TempData["Message"] is string message)
    {
        <div class="alert success">@message</div>
    }

    @if (TempData["Warning"] is string warning)
    {
        <div class="alert warning">@warning</div>
    }

    <section class="audit-index-card">
        <h2>Φάκελοι</h2>
        <p class="muted">
            Οι φάκελοι λειτουργούν σαν περίοδοι απογραφής. Οι πρόχειροι φάκελοι μπορούν να καθαριστούν ή να διαγραφούν αν έγιναν λάθος.
        </p>

        @if (!Model.Folders.Any())
        {
            <div class="audit-index-empty">
                <h3>Δεν υπάρχει ακόμα φάκελος απογραφής</h3>
                <p>Ξεκίνα δημιουργώντας έναν νέο φάκελο. Θα δημιουργηθούν αυτόματα εγγραφές χώρων με βάση τον ενεργό εξοπλισμό.</p>
            </div>
        }
        else
        {
            <div class="audit-index-table-wrap">
                <table class="audit-index-table">
                    <thead>
                        <tr>
                            <th>Φάκελος</th>
                            <th>Ημερομηνία</th>
                            <th>Χώροι</th>
                            <th>Πρόοδος</th>
                            <th>Θέματα</th>
                            <th>Κατάσταση</th>
                            <th class="audit-index-actions-heading">Ενέργειες</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var folder in Model.Folders)
                        {
                            var totalRooms = folder.RoomSessions.Count;
                            var finalizedRooms = folder.RoomSessions.Count(x => x.IsFinalized);
                            var expected = folder.RoomSessions.Sum(x => x.ExpectedItemsCount);
                            var found = folder.RoomSessions.Sum(x => x.FoundItemsCount);
                            var missing = folder.RoomSessions.Sum(x => x.MissingItemsCount);
                            var problems = folder.RoomSessions.Sum(x => x.WrongRoomItemsCount + x.UnknownItemsCount);
                            var scans = folder.RoomSessions.Sum(x => x.ScanLogs?.Count ?? 0);
                            var statusText = folder.IsFinalized ? "Οριστικοποιημένος" : "Πρόχειρος";

                            <tr>
                                <td>
                                    <strong>@folder.Title</strong>
                                    <br />
                                    <span class="muted">@folder.SchoolName · @folder.SchoolYear</span>
                                </td>
                                <td>@folder.AuditDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @finalizedRooms / @totalRooms κλειστοί
                                    <br />
                                    <span class="muted">@scans καταχωρήσεις</span>
                                </td>
                                <td>
                                    <strong>@found / @expected</strong>
                                    <br />
                                    <span class="muted">@missing λείπουν</span>
                                </td>
                                <td>@problems</td>
                                <td>
                                    <span class="audit-index-status @(folder.IsFinalized ? "final" : "")">@statusText</span>
                                </td>
                                <td class="audit-index-actions-cell">
                                    <div class="audit-index-row-actions">
                                        <a class="btn secondary audit-index-open-action" asp-page="/InventoryAudits/Details" asp-route-id="@folder.Id">Άνοιγμα φακέλου</a>

                                        @if (!folder.IsFinalized)
                                        {
                                            <div class="audit-index-danger-zone">
                                                <form class="audit-index-inline-form" method="post" asp-page-handler="ClearScans" asp-route-id="@folder.Id"
                                                      onsubmit="return confirm('Να καθαριστούν όλες οι καταχωρήσεις/scans αυτού του φακέλου; Ο φάκελος και οι χώροι θα μείνουν, αλλά η πρόοδος θα μηδενιστεί.');">
                                                    <button type="submit" class="btn secondary">Καθαρισμός</button>
                                                </form>

                                                <form class="audit-index-inline-form" method="post" asp-page-handler="Delete" asp-route-id="@folder.Id"
                                                      onsubmit="return confirm('Να διαγραφεί ο πρόχειρος φάκελος απογραφής; Θα διαγραφούν και οι χώροι/καταχωρήσεις του φακέλου. Τα αντικείμενα απογραφής ΔΕΝ διαγράφονται.');">
                                                    <button type="submit" class="btn danger">Διαγραφή</button>
                                                </form>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
