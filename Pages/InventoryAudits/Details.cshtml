@page "{id:int}"
@model SchoolInventoryManager.Pages.InventoryAudits.DetailsModel

@{
    ViewData["Title"] = Model.Folder?.Title ?? "Φάκελος απογραφής";
    var folder = Model.Folder!;
}

<style>
    .audit-details-page {
        max-width: 1180px;
        margin: 0 auto;
        padding-bottom: 3rem;
    }

    .audit-details-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: center;
        padding: 1.35rem;
        border: 1px solid rgba(34, 211, 238, .22);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .14), transparent 38%),
            linear-gradient(135deg, rgba(15, 23, 42, .98), rgba(17, 24, 39, .92));
        box-shadow: 0 18px 42px rgba(0, 0, 0, .28);
        margin-bottom: 1rem;
    }

    .audit-details-hero h1 {
        margin: 0;
    }

    .audit-details-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .55rem;
        justify-content: flex-end;
    }

    .audit-details-card {
        border: 1px solid rgba(148, 163, 184, .16);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .06), transparent 40%),
            rgba(15, 23, 42, .82);
        padding: 1rem;
        box-shadow: 0 14px 34px rgba(0, 0, 0, .22);
        margin-bottom: 1rem;
    }

    .audit-details-badge {
        display: inline-flex;
        width: fit-content;
        padding: .25rem .55rem;
        border-radius: 999px;
        border: 1px solid rgba(34, 211, 238, .32);
        color: #a5f3fc;
        background: rgba(8, 47, 73, .42);
        font-weight: 800;
        font-size: .72rem;
        letter-spacing: .03em;
        text-transform: uppercase;
        margin-bottom: .65rem;
    }

    .audit-details-stats {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: .75rem;
        margin-bottom: 1rem;
    }

    .audit-details-stat {
        padding: .85rem;
        border: 1px solid rgba(148, 163, 184, .15);
        border-radius: 16px;
        background: rgba(2, 6, 23, .36);
    }

    .audit-details-stat span {
        display: block;
        color: #94a3b8;
        font-size: .8rem;
        margin-bottom: .25rem;
    }

    .audit-details-stat strong {
        display: block;
        font-size: 1.4rem;
        line-height: 1;
    }

    .audit-details-stat.success strong { color: #34d399; }
    .audit-details-stat.warning strong { color: #f59e0b; }
    .audit-details-stat.danger strong { color: #f87171; }

    .audit-details-table-wrap {
        overflow-x: auto;
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, .14);
    }

    .audit-details-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 920px;
    }

    .audit-details-table th,
    .audit-details-table td {
        padding: .85rem;
        border-bottom: 1px solid rgba(148, 163, 184, .12);
        text-align: left;
        vertical-align: top;
    }

    .audit-details-table th {
        color: #e5eefb;
        background: rgba(8, 47, 73, .36);
    }

    .audit-details-table td {
        color: #cbd5e1;
    }

    .audit-details-table tr:last-child td {
        border-bottom: 0;
    }

    .audit-details-status {
        display: inline-flex;
        padding: .25rem .55rem;
        border-radius: 999px;
        font-weight: 800;
        font-size: .75rem;
        background: rgba(245, 158, 11, .15);
        color: #fcd34d;
        border: 1px solid rgba(245, 158, 11, .35);
    }

    .audit-details-status.done {
        background: rgba(52, 211, 153, .15);
        color: #86efac;
        border-color: rgba(52, 211, 153, .35);
    }

    .audit-details-inline-form {
        display: inline;
    }

    .audit-details-room-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
    }

    @@media (max-width: 900px) {
        .audit-details-hero {
            grid-template-columns: 1fr;
        }

        .audit-details-actions {
            justify-content: flex-start;
        }

        .audit-details-stats {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
</style>

<div class="audit-details-page">
    <section class="audit-details-hero">
        <div>
            <span class="audit-details-badge">Φάκελος απογραφής</span>
            <h1>@folder.Title</h1>
            <p class="muted">
                @folder.SchoolName · @(string.IsNullOrWhiteSpace(folder.SchoolType) ? "Σχολική μονάδα" : folder.SchoolType) ·
                @folder.SchoolYear · @folder.AuditDate.ToString("dd/MM/yyyy")
            </p>
        </div>

        <div class="audit-details-actions">
            <a class="btn secondary" asp-page="/InventoryAudits/Index">Φάκελοι</a>
            <a class="btn secondary" asp-page="/Audit/Room">Χειροκίνητος έλεγχος</a>

            <form class="audit-details-inline-form" method="post" asp-page-handler="Recalculate" asp-route-id="@folder.Id">
                <button class="btn secondary" type="submit">Ενημέρωση συνόλων</button>
            </form>

            @if (!folder.IsFinalized)
            {
                <form class="audit-details-inline-form" method="post" asp-page-handler="Finalize" asp-route-id="@folder.Id"
                      onsubmit="return confirm('Να οριστικοποιηθεί ο φάκελος απογραφής; Μετά δεν θα μπορεί να διαγραφεί ή να καθαριστεί.');">
                    <button class="btn primary" type="submit">Οριστικοποίηση φακέλου</button>
                </form>
            }
        </div>
    </section>

    @if (TempData["Message"] is string message)
    {
        <div class="alert success">@message</div>
    }

    @if (TempData["Warning"] is string warning)
    {
        <div class="alert warning">@warning</div>
    }

    <section class="audit-details-card">
        <div class="audit-details-stats">
            <article class="audit-details-stat">
                <span>Αναμενόμενα</span>
                <strong>@Model.TotalExpected</strong>
            </article>

            <article class="audit-details-stat success">
                <span>Βρέθηκαν</span>
                <strong>@Model.TotalFound</strong>
            </article>

            <article class="audit-details-stat warning">
                <span>Λείπουν</span>
                <strong>@Model.TotalMissing</strong>
            </article>

            <article class="audit-details-stat danger">
                <span>Θέματα</span>
                <strong>@Model.TotalProblems</strong>
            </article>

            <article class="audit-details-stat">
                <span>Χώροι κλειστοί</span>
                <strong>@Model.FinalizedRooms / @folder.RoomSessions.Count</strong>
            </article>
        </div>

        <p class="muted">
            Σύνολο καταχωρήσεων/scans: <strong>@Model.TotalScans</strong> ·
            Κατάσταση φακέλου: <strong>@(folder.IsFinalized ? "Οριστικοποιημένος" : "Πρόχειρος")</strong>
        </p>

        @if (!folder.IsFinalized)
        {
            <div class="audit-details-actions" style="justify-content:flex-start;">
                <form class="audit-details-inline-form" method="post" asp-page-handler="ClearScans" asp-route-id="@folder.Id"
                      onsubmit="return confirm('Να καθαριστούν ΟΛΕΣ οι καταχωρήσεις/scans του φακέλου; Τα αντικείμενα δεν διαγράφονται, μόνο η πρόοδος απογραφής.');">
                    <button class="btn secondary" type="submit">Καθαρισμός scans φακέλου</button>
                </form>

                <form class="audit-details-inline-form" method="post" asp-page-handler="Delete" asp-route-id="@folder.Id"
                      onsubmit="return confirm('Να διαγραφεί ο πρόχειρος φάκελος απογραφής; Θα διαγραφούν οι χώροι/καταχωρήσεις αυτού του φακέλου. Τα αντικείμενα απογραφής ΔΕΝ διαγράφονται.');">
                    <button class="btn danger" type="submit">Διαγραφή πρόχειρου φακέλου</button>
                </form>
            </div>
        }
    </section>

    <section class="audit-details-card">
        <h2>Χώροι φακέλου</h2>
        <p class="muted">
            Άνοιξε κάθε χώρο, έλεγξε τις καταχωρήσεις και οριστικοποίησε τον χώρο όταν ολοκληρωθεί.
        </p>

        @if (!folder.RoomSessions.Any())
        {
            <div class="empty-state">
                <h3>Δεν υπάρχουν χώροι στον φάκελο</h3>
                <p>Πιθανόν δεν υπήρχαν ενεργά αντικείμενα κατά τη δημιουργία του φακέλου.</p>
            </div>
        }
        else
        {
            <div class="audit-details-table-wrap">
                <table class="audit-details-table">
                    <thead>
                        <tr>
                            <th>Χώρος</th>
                            <th>Αναμενόμενα</th>
                            <th>Βρέθηκαν</th>
                            <th>Λείπουν</th>
                            <th>Θέματα</th>
                            <th>Σαρώσεις</th>
                            <th>Κατάσταση</th>
                            <th>Ενέργειες</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in folder.RoomSessions.OrderBy(x => x.RoomNameSnapshot))
                        {
                            var problems = session.WrongRoomItemsCount + session.UnknownItemsCount;
                            var scans = session.ScanLogs?.Count ?? 0;
                            var isCompleted = session.ExpectedItemsCount > 0 && session.MissingItemsCount == 0;
                            var status = session.IsFinalized ? "Οριστικοποιημένος" : (isCompleted ? "Ολοκληρωμένος" : "Πρόχειρος");

                            <tr>
                                <td>
                                    <strong>@session.RoomNameSnapshot</strong>
                                    @if (session.CompletedAt.HasValue)
                                    {
                                        <br />
                                        <span class="muted">Ολοκλήρωση: @session.CompletedAt.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                    }
                                </td>
                                <td>@session.ExpectedItemsCount</td>
                                <td>@session.FoundItemsCount</td>
                                <td>@session.MissingItemsCount</td>
                                <td>@problems</td>
                                <td>@scans</td>
                                <td>
                                    <span class="audit-details-status @(session.IsFinalized || isCompleted ? "done" : "")">@status</span>
                                </td>
                                <td>
                                    <div class="audit-details-room-actions">
                                        <a class="btn secondary"
                                           asp-page="/Audit/Room"
                                           asp-route-folderId="@folder.Id"
                                           asp-route-roomSessionId="@session.Id"
                                           asp-route-roomId="@session.RoomId">
                                            Άνοιγμα
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
