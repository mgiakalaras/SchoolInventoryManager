@page
@model SchoolInventoryManager.Pages.Labels.MobileFindingsModel

@{
    ViewData["Title"] = "QR νέων ευρημάτων";
    var currentReturnUrl = Url.Page(
        "/Labels/MobileFindings",
        new
        {
            search = Model.Search,
            roomId = Model.RoomId,
            includeInactive = Model.IncludeInactive
        });

    var labelPages = Model.Items
        .Select((item, index) => new { item, index })
        .GroupBy(x => x.index / 21)
        .Select(g => g.Select(x => x.item).ToList())
        .ToList();
}

<style>
    .new-qr-page {
        max-width: 1180px;
        margin: 0 auto;
        padding-bottom: 3rem;
    }

    .new-qr-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: center;
        padding: 1.35rem;
        border: 1px solid rgba(34, 211, 238, .22);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .14), transparent 38%),
            linear-gradient(135deg, rgba(15, 23, 42, .98), rgba(17, 24, 39, .92));
        box-shadow: 0 18px 42px rgba(0, 0, 0, .28);
        margin-bottom: 1rem;
    }

    .new-qr-hero h1,
    .new-qr-card h2,
    .new-qr-card h3 {
        margin: 0;
    }

    .new-qr-badge {
        display: inline-flex;
        width: fit-content;
        padding: .25rem .55rem;
        border-radius: 999px;
        border: 1px solid rgba(34, 211, 238, .32);
        color: #a5f3fc;
        background: rgba(8, 47, 73, .42);
        font-weight: 800;
        font-size: .72rem;
        letter-spacing: .03em;
        text-transform: uppercase;
        margin-bottom: .65rem;
    }

    .new-qr-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .55rem;
        justify-content: flex-end;
    }

    .new-qr-card {
        border: 1px solid rgba(148, 163, 184, .16);
        border-radius: 22px;
        background:
            radial-gradient(circle at top left, rgba(34, 211, 238, .06), transparent 40%),
            rgba(15, 23, 42, .82);
        padding: 1rem;
        box-shadow: 0 14px 34px rgba(0, 0, 0, .22);
        margin-bottom: 1rem;
    }

    .new-qr-workflow {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: .75rem;
        margin-top: 1rem;
    }

    .new-qr-step {
        display: grid;
        grid-template-columns: 38px minmax(0, 1fr);
        gap: .75rem;
        align-items: start;
        padding: .85rem;
        border: 1px solid rgba(148, 163, 184, .14);
        border-radius: 16px;
        background: rgba(2, 6, 23, .30);
    }

    .new-qr-step-number {
        display: grid;
        place-items: center;
        width: 34px;
        height: 34px;
        border-radius: 12px;
        background: rgba(34, 211, 238, .14);
        color: #67e8f9;
        font-weight: 900;
        border: 1px solid rgba(34, 211, 238, .32);
    }

    .new-qr-step strong,
    .new-qr-step span {
        display: block;
    }

    .new-qr-step span {
        color: #94a3b8;
        margin-top: .2rem;
    }

    .new-qr-toolbar {
        position: sticky;
        top: .75rem;
        z-index: 5;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: center;
        border-color: rgba(52, 211, 153, .30);
        background:
            radial-gradient(circle at top left, rgba(52, 211, 153, .10), transparent 36%),
            rgba(6, 30, 25, .88);
    }

    .new-qr-stats {
        display: flex;
        flex-wrap: wrap;
        gap: .55rem;
        align-items: center;
    }

    .new-qr-pill {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .35rem .65rem;
        border-radius: 999px;
        border: 1px solid rgba(148, 163, 184, .18);
        background: rgba(2, 6, 23, .32);
        color: #cbd5e1;
        font-weight: 800;
        font-size: .82rem;
    }

    .new-qr-filter {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) minmax(220px, 320px) auto auto;
        gap: .75rem;
        align-items: end;
    }

    .new-qr-filter label span {
        display: block;
        font-weight: 800;
        margin-bottom: .35rem;
    }

    .new-qr-filter input[type="text"],
    .new-qr-filter select {
        width: 100%;
        min-height: 42px;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, .22);
        background: rgba(2, 6, 23, .45);
        color: #e5eefb;
        padding: .65rem .75rem;
    }

    .new-qr-check {
        display: flex;
        gap: .45rem;
        align-items: center;
        min-height: 42px;
        color: #cbd5e1;
    }

    .new-qr-room-group {
        margin-top: 1rem;
    }

    .new-qr-room-title {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: .85rem 1rem;
        border-radius: 16px;
        border: 1px solid rgba(34, 211, 238, .18);
        background: rgba(8, 47, 73, .28);
        margin-bottom: .65rem;
    }

    .new-qr-list {
        display: grid;
        gap: .65rem;
    }

    .new-qr-row {
        display: grid;
        grid-template-columns: 34px 74px minmax(0, 1fr) auto;
        gap: .85rem;
        align-items: center;
        border: 1px solid rgba(148, 163, 184, .13);
        border-radius: 18px;
        background: rgba(2, 6, 23, .33);
        padding: .85rem;
    }

    .new-qr-row input[type="checkbox"] {
        width: 22px;
        height: 22px;
    }

    .new-qr-row img {
        width: 64px;
        height: 64px;
        border-radius: 12px;
        background: white;
        padding: 5px;
    }

    .new-qr-row strong,
    .new-qr-row span,
    .new-qr-row small {
        display: block;
    }

    .new-qr-row span,
    .new-qr-row small {
        color: #94a3b8;
    }

    .new-qr-row-title {
        display: flex;
        gap: .5rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .new-qr-code {
        display: inline-flex;
        width: fit-content;
        padding: .18rem .45rem;
        border-radius: 999px;
        background: rgba(34, 211, 238, .10);
        border: 1px solid rgba(34, 211, 238, .22);
        color: #a5f3fc;
        font-size: .76rem;
        font-weight: 900;
    }

    .new-qr-row-actions {
        display: grid;
        grid-template-columns: minmax(150px, 1fr);
        gap: .45rem;
        min-width: 170px;
    }

    .new-qr-row-actions .btn {
        width: 100%;
        justify-content: center;
        text-align: center;
        white-space: nowrap;
    }

    .new-qr-warning {
        border-color: rgba(245, 158, 11, .32);
        background:
            radial-gradient(circle at top left, rgba(245, 158, 11, .11), transparent 36%),
            rgba(30, 23, 10, .72);
    }

    .new-qr-empty {
        text-align: center;
        padding: 2rem;
        border: 1px dashed rgba(148, 163, 184, .22);
        border-radius: 18px;
        color: #94a3b8;
    }

    .qr-print-root {
        margin-top: 18px;
    }

    .qr-label-page {
        display: grid;
        grid-template-columns: repeat(3, 70mm);
        grid-template-rows: repeat(7, 42.3mm);
        grid-auto-flow: column;
        width: 210mm;
        min-height: 297mm;
        margin: 0 auto 14px;
        padding: 0;
        background: #ffffff;
        border: 1px solid rgba(148, 163, 184, 0.18);
        box-sizing: border-box;
    }

    .qr-print-label {
        width: 70mm;
        height: 42.3mm;
        border: 1px dashed rgba(148, 163, 184, 0.35);
        border-radius: 0;
        background: #ffffff;
        color: #111827;
        display: grid;
        grid-template-columns: 32mm minmax(0, 1fr);
        gap: 2mm;
        align-items: center;
        padding: 2.2mm;
        box-sizing: border-box;
        overflow: hidden;
        break-inside: avoid;
        page-break-inside: avoid;
    }

    .qr-print-image-box {
        width: 30mm;
        height: 30mm;
        background: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        justify-self: center;
        align-self: center;
        overflow: hidden;
        flex: 0 0 auto;
    }

    .qr-print-image-box img {
        width: 30mm !important;
        height: 30mm !important;
        max-width: 30mm !important;
        max-height: 30mm !important;
        object-fit: contain;
        display: block;
        background: #ffffff;
        image-rendering: pixelated;
    }

    .qr-print-text {
        min-width: 0;
        font-family: "Segoe UI", Arial, sans-serif;
        overflow: hidden;
        position: relative;
        z-index: 2;
        background: #ffffff;
    }

    .qr-print-text strong,
    .qr-print-text span {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .qr-print-text strong {
        font-size: 8.5pt;
        font-weight: 900;
        color: #111827;
        margin-bottom: 1mm;
        white-space: nowrap;
    }

    .qr-print-text span {
        font-size: 7pt;
        line-height: 1.12;
        color: #111827;
    }

    .qr-print-text .label-item-name {
        font-weight: 800;
        font-size: 7.6pt;
        max-height: 16pt;
    }

    @@media print {
        .topbar,
        .footer,
        .mobile-bottom-nav,
        .screen-only,
        .no-print {
            display: none !important;
        }

        html,
        body,
        body.sim-ops-theme {
            width: 210mm !important;
            min-width: 210mm !important;
            max-width: 210mm !important;
            margin: 0 !important;
            padding: 0 !important;
            background: #ffffff !important;
            color: #000000 !important;
            display: block !important;
            min-height: 0 !important;
            height: auto !important;
            overflow: visible !important;
        }

        body.sim-ops-theme main.container,
        body.sim-ops-theme .container,
        .container,
        main {
            width: 210mm !important;
            max-width: 210mm !important;
            min-width: 210mm !important;
            margin: 0 !important;
            padding: 0 !important;
            overflow: visible !important;
            display: block !important;
        }

        .qr-print-root {
            /* Same calibrated print engine as Pages/Labels/Qr.cshtml.
               Typotrust TL2111: 3 columns x 7 rows, 70mm x 42.3mm.
               Previously calibrated top offset: -18mm. */
            --label-offset-x: 0mm;
            --label-offset-y: -18mm;
            width: 210mm !important;
            max-width: 210mm !important;
            min-width: 210mm !important;
            margin: 0 !important;
            padding: 0 !important;
            background: #ffffff !important;
            position: relative !important;
            top: 0 !important;
            left: 0 !important;
            transform: translate(var(--label-offset-x), var(--label-offset-y)) !important;
            line-height: 1 !important;
            font-size: 0 !important;
        }

        .qr-label-page {
            display: grid !important;
            grid-template-columns: repeat(3, 70mm) !important;
            grid-template-rows: repeat(7, 42.3mm) !important;
            grid-auto-flow: column !important;
            width: 210mm !important;
            min-width: 210mm !important;
            max-width: 210mm !important;
            height: 297mm !important;
            min-height: 297mm !important;
            max-height: 297mm !important;
            margin: 0 !important;
            padding: 0 !important;
            border: none !important;
            box-sizing: border-box !important;
            background: #ffffff !important;
            overflow: hidden !important;
            position: relative !important;
            top: 0 !important;
            left: 0 !important;
            page-break-after: always;
            break-after: page;
        }

        .qr-label-page:last-child {
            page-break-after: auto;
            break-after: auto;
        }

        .qr-label-page.is-print-hidden {
            display: none !important;
        }

        .qr-print-label {
            width: 70mm !important;
            height: 42.3mm !important;
            border: none !important;
            border-radius: 0 !important;
            overflow: hidden !important;
            box-sizing: border-box !important;
        }

        .qr-print-label.is-print-hidden {
            display: none !important;
        }

        .qr-print-image-box {
            width: 30mm !important;
            height: 30mm !important;
            overflow: hidden !important;
        }

        .qr-print-image-box img {
            width: 30mm !important;
            height: 30mm !important;
            max-width: 30mm !important;
            max-height: 30mm !important;
        }

        @@page {
            size: 210mm 297mm;
            margin: 0;
        }
    }


    @@media (max-width: 900px) {
        .new-qr-hero,
        .new-qr-toolbar,
        .new-qr-filter,
        .new-qr-row,
        .new-qr-workflow {
            grid-template-columns: 1fr;
        }

        .new-qr-actions {
            justify-content: flex-start;
        }

        .new-qr-row-actions {
            min-width: 0;
        }
    }
</style>

<div class="new-qr-page screen-only">
    <section class="new-qr-hero">
        <div>
            <span class="new-qr-badge">QR labels</span>
            <h1>QR νέων ευρημάτων</h1>
            <p class="muted">
                Έλεγξε τα στοιχεία, διάλεξε τι θες να τυπώσεις και βγάλε αμέσως QR για τα αντικείμενα που βρέθηκαν από κινητό/tablet.
            </p>
        </div>

        <div class="new-qr-actions">
            <a class="btn secondary" asp-page="/InventoryAudits/MobileFindings">Λίστα νέων ευρημάτων</a>
            <a class="btn secondary" asp-page="/InventoryAudits/Index">Φάκελοι απογραφής</a>
        </div>
    </section>

    <section class="new-qr-card new-qr-warning">
        <h2>Ροή εργασίας</h2>
        <div class="new-qr-workflow">
            <article class="new-qr-step">
                <span class="new-qr-step-number">1</span>
                <div>
                    <strong>Έλεγξε τα στοιχεία</strong>
                    <span>Πάτησε Επεξεργασία για να συμπληρώσεις serial, κατηγορία, μάρκα ή μοντέλο.</span>
                </div>
            </article>

            <article class="new-qr-step">
                <span class="new-qr-step-number">2</span>
                <div>
                    <strong>Διάλεξε ετικέτες</strong>
                    <span>Άφησε επιλεγμένα μόνο όσα θέλεις να τυπωθούν τώρα.</span>
                </div>
            </article>

            <article class="new-qr-step">
                <span class="new-qr-step-number">3</span>
                <div>
                    <strong>Εκτύπωσε QR</strong>
                    <span>Μετά την εκτύπωση μπορείς να επιστρέψεις στην απογραφή και να συνεχίσεις.</span>
                </div>
            </article>
        </div>
    </section>

    <section class="new-qr-card new-qr-toolbar">
        <div>
            <h2>Εκτύπωση</h2>
            <div class="new-qr-stats">
                <span class="new-qr-pill"><strong>@Model.TotalRows</strong> ετικέτες</span>
                <span class="new-qr-pill"><strong>@Model.RoomsCount</strong> χώροι</span>
                <span class="new-qr-pill">A4 · 21 ετικέτες / φύλλο</span>
            </div>
        </div>

        <div class="new-qr-actions">
            <button type="button" class="btn primary" onclick="printSelectedMobileFindingLabels()">Εκτύπωση επιλεγμένων QR</button>
            <button type="button" class="btn secondary" onclick="selectAllMobileFindingLabels(true)">Επιλογή όλων</button>
            <button type="button" class="btn secondary" onclick="selectAllMobileFindingLabels(false)">Καμία</button>
        </div>
    </section>

    <section class="new-qr-card">
        <h2>Φίλτρα</h2>

        <form method="get" class="new-qr-filter">
            <label>
                <span>Αναζήτηση</span>
                <input asp-for="Search" type="text" placeholder="όνομα, κωδικός, serial..." />
            </label>

            <label>
                <span>Χώρος</span>
                <select asp-for="RoomId" asp-items="Model.Rooms">
                    <option value="">Όλοι οι χώροι</option>
                </select>
            </label>

            <label class="new-qr-check">
                <input asp-for="IncludeInactive" />
                <span>Και ανενεργά</span>
            </label>

            <button type="submit" class="btn primary">Εφαρμογή</button>
        </form>
    </section>

    <section class="new-qr-card">
        <h2>Έλεγχος & επιλογή ετικετών</h2>
        <p class="muted">
            Δεν χρειάζεται να ανοίξεις ξεχωριστή καρτέλα QR για κάθε αντικείμενο. Από εδώ ελέγχεις, επεξεργάζεσαι και τυπώνεις απευθείας.
        </p>

        @if (!Model.Items.Any())
        {
            <div class="new-qr-empty">
                <h3>Δεν υπάρχουν νέα ευρήματα για QR</h3>
                <p>Πρόσθεσε νέο αντικείμενο από την Android εφαρμογή ή καθάρισε τα φίλτρα.</p>
            </div>
        }
        else
        {
            @foreach (var group in Model.Items.GroupBy(x => x.RoomName).OrderBy(x => x.Key))
            {
                <div class="new-qr-room-group">
                    <div class="new-qr-room-title">
                        <strong>@group.Key</strong>
                        <span class="muted">@group.Count() ετικέτες</span>
                    </div>

                    <div class="new-qr-list">
                        @foreach (var item in group)
                        {
                            var missingSerial = string.IsNullOrWhiteSpace(item.SerialNumber);
                            var missingBrandModel = string.IsNullOrWhiteSpace(item.BrandModel);

                            <article class="new-qr-row">
                                <input type="checkbox" class="mobile-finding-label-checkbox" data-label-id="label-@item.Id" value="@item.Id" checked />

                                <img src="@item.QrImageDataUrl" alt="QR @item.AssetCode" />

                                <div>
                                    <div class="new-qr-row-title">
                                        <strong>@item.Name</strong>
                                        <span class="new-qr-code">@item.AssetCode</span>
                                    </div>

                                    <span>@item.CategoryName · @item.RoomName</span>
                                    <small>
                                        @(missingBrandModel ? "Χωρίς μάρκα/μοντέλο" : item.BrandModel)
                                        · SN: @(missingSerial ? "λείπει" : item.SerialNumber)
                                        · Ποσότητα: @item.Quantity
                                    </small>

                                    @if (missingSerial || missingBrandModel)
                                    {
                                        <small style="color:#fcd34d;">Προτείνεται έλεγχος πριν την εκτύπωση.</small>
                                    }
                                </div>

                                <div class="new-qr-row-actions">
                                    <a class="btn primary"
                                       asp-page="/Items/Edit"
                                       asp-route-id="@item.Id"
                                       asp-route-returnUrl="@currentReturnUrl">
                                        Επεξεργασία στοιχείων
                                    </a>
                                </div>
                            </article>
                        }
                    </div>
                </div>
            }
        }
    </section>
</div>

<section class="qr-print-root" aria-label="Εκτύπωση QR ετικετών νέων ευρημάτων">
    @foreach (var pageItems in labelPages)
    {
        <section class="qr-label-page">
            @foreach (var item in pageItems)
            {
                <article class="qr-print-label" id="label-@item.Id">
                    <div class="qr-print-image-box">
                        <img src="@item.QrImageDataUrl" alt="QR @item.AssetCode" />
                    </div>

                    <div class="qr-print-text">
                        <strong>@item.AssetCode</strong>
                        <span class="label-item-name">@item.Name</span>
                        <span>@item.RoomName</span>
                        <span>Απογραφή: @item.InventoryDateText</span>

                        @if (!string.IsNullOrWhiteSpace(item.SerialNumber))
                        {
                            <span>SN: @item.SerialNumber</span>
                        }
                    </div>
                </article>
            }
        </section>
    }
</section>

<script>
    function selectAllMobileFindingLabels(checked) {
        document.querySelectorAll(".mobile-finding-label-checkbox").forEach(function (checkbox) {
            checkbox.checked = checked;
        });

        syncMobileFindingLabelVisibility();
    }

    function syncMobileFindingLabelVisibility() {
        document.querySelectorAll(".mobile-finding-label-checkbox").forEach(function (checkbox) {
            const labelId = checkbox.getAttribute("data-label-id");
            const label = document.getElementById(labelId);

            if (!label) {
                return;
            }

            label.classList.toggle("is-print-hidden", !checkbox.checked);
        });

        document.querySelectorAll(".qr-label-page").forEach(function (page) {
            const visibleLabels = Array.from(page.querySelectorAll(".qr-print-label"))
                .filter(function (label) { return !label.classList.contains("is-print-hidden"); });

            page.classList.toggle("is-print-hidden", visibleLabels.length === 0);
        });
    }

    function printSelectedMobileFindingLabels() {
        syncMobileFindingLabelVisibility();

        const selectedCount = Array.from(document.querySelectorAll(".mobile-finding-label-checkbox"))
            .filter(function (checkbox) { return checkbox.checked; })
            .length;

        if (selectedCount === 0) {
            alert("Δεν έχεις επιλέξει καμία ετικέτα για εκτύπωση.");
            return;
        }

        window.print();
    }

    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".mobile-finding-label-checkbox").forEach(function (checkbox) {
            checkbox.addEventListener("change", syncMobileFindingLabelVisibility);
        });

        syncMobileFindingLabelVisibility();
    });
</script>
