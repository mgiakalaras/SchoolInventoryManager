        grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
        gap: .65rem;
    }

    .sim47-equipment-tile {
        display: grid;
        grid-template-columns: 42px minmax(0, 1fr);
        gap: .65rem;
        border-radius: 18px;
        padding: .75rem;
    }

    .sim47-equipment-tile i,
    .sim47-room-flow i {
        grid-column: 1 / -1;
        display: block;
        height: 7px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(148, 163, 184, .14);
    }

    .sim47-equipment-tile i span,
    .sim47-room-flow i span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #22d3ee, #818cf8);
    }

    .sim47-room-flow {
        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    }

    .sim47-room-flow a {
        border-radius: 18px;
        padding: .75rem;
        display: grid;
        gap: .45rem;
    }

    .sim47-room-flow strong,
    .sim47-room-flow span {
